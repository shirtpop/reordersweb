<div class="flex justify-between items-center py-3 px-4 bg-gray-50 rounded-lg border border-gray-200"
     data-controller="cart-item"
     id="cart_item_<%= item.id %>">
  <div class="flex items-center gap-4">
    <% color_data = product.product_colors.find { |c| c.name == item.color } %>
    <% if color_data %>
      <div class="w-8 h-8 rounded-full border-2 border-gray-300 shadow-sm"
           style="background-color: <%= color_data.hex_color %>"
           title="<%= item.color %>"></div>
    <% end %>

    <div>
      <span class="font-semibold text-gray-900"><%= item.color %></span>
      <span class="text-gray-500 mx-2">•</span>
      <span class="font-semibold text-gray-900">Size <%= item.size %></span>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= form_with model: item, url: cart_item_path(item), method: :patch,
        data: { "cart-item-target": "form" },
        class: "flex items-center gap-2" do |f| %>
      <%= f.number_field :quantity,
          id: "cart_item_#{item.id}_quantity",
          value: item.quantity,
          min: 0,
          data: {
            "cart-item-target": "quantityInput",
            action: "input->cart-item#updateQuantity"
          },
          class: "w-20 text-center border-2 border-gray-300 rounded-xl py-3 font-bold text-pink-600 text-lg focus:outline-none focus:ring-2 focus:ring-pink-500 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" %>
      <%= f.hidden_field :order_id, value: cart.id %>
    <% end %>
  </div>
</div>
