<div class="container mx-auto px-4 py-6">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Orders</h1>
    <p class="text-sm text-gray-500 mt-1">Track and manage your orders</p>
  </div>

  <% if @orders.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <ul class="divide-y divide-gray-100">
        <% @orders.each do |order| %>
          <%= link_to order_path(order), class: "block px-5 py-4 hover:bg-pink-50 transition-colors duration-150 group" do %>
            <div class="flex items-start justify-between gap-4">
              <!-- Left: number badge + primary info -->
              <div class="flex items-start gap-3 min-w-0">
                <div class="flex-shrink-0 w-8 h-8 bg-gradient-to-br from-pink-600 to-rose-600 rounded-lg flex items-center justify-center shadow-sm mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                  </svg>
                </div>
                <div class="min-w-0">
                  <!-- Row 1: order number + status -->
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-sm font-semibold text-gray-900"><%= order.order_number %></span>
                    <%= render "orders/status_badge", order: order %>
                  </div>
                  <!-- Row 2: metadata chips -->
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1.5">
                    <% if order.submitted_at.present? %>
                      <span class="inline-flex items-center gap-1 text-xs text-gray-500">
                        <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Submitted <%= order.submitted_at.strftime("%b %d, %Y") %>
                      </span>
                    <% end %>
                    <% if order.delivery_date.present? %>
                      <span class="inline-flex items-center gap-1 text-xs text-gray-500">
                        <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        Delivery <%= order.delivery_date.strftime("%b %d, %Y") %>
                      </span>
                    <% end %>
                    <span class="inline-flex items-center gap-1 text-xs text-gray-500">
                      <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                      </svg>
                      <%= order.total_quantity %> items
                    </span>
                    <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-700">
                      <svg class="w-3 h-3 flex-shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      $<%= number_with_precision(order.price, precision: 2, delimiter: ',') %>
                    </span>
                    <% if order.ordered_by.present? %>
                      <span class="inline-flex items-center gap-1 text-xs text-gray-500">
                        <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        By <%= order.ordered_by.email %>
                      </span>
                    <% end %>
                    <% if order.received_by.present? %>
                      <span class="inline-flex items-center gap-1 text-xs text-emerald-600">
                        <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Received by <%= order.received_by.email %>
                      </span>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Right: chevron -->
              <svg class="w-4 h-4 text-gray-400 group-hover:text-pink-500 transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          <% end %>
        <% end %>
      </ul>

      <% if @pagy.pages > 1 %>
        <div class="border-t border-gray-100 px-5 py-3 flex items-center justify-between bg-gray-50">
          <p class="text-xs text-gray-500">
            Showing <span class="font-medium text-gray-700"><%= @pagy.from %></span>–<span class="font-medium text-gray-700"><%= @pagy.to %></span> of <span class="font-medium text-gray-700"><%= @pagy.count %></span>
          </p>
          <nav class="inline-flex items-center gap-1">
            <% if @pagy.prev %>
              <%= link_to orders_path(page: @pagy.prev), class: "inline-flex items-center justify-center w-8 h-8 rounded-md border border-gray-300 bg-white text-gray-500 hover:bg-pink-50 hover:border-pink-300 hover:text-pink-600 transition-colors" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              <% end %>
            <% else %>
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-md border border-gray-200 bg-gray-100 text-gray-300 cursor-not-allowed">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </span>
            <% end %>
            <% @pagy.series.each do |item| %>
              <% if item.is_a?(Integer) %>
                <%= link_to item, orders_path(page: item),
                    class: "inline-flex items-center justify-center w-8 h-8 rounded-md border text-sm font-medium transition-colors #{item == @pagy.page ? 'bg-pink-600 border-pink-600 text-white shadow-sm' : 'border-gray-300 bg-white text-gray-700 hover:bg-pink-50 hover:border-pink-300 hover:text-pink-600'}" %>
              <% elsif item == :gap %>
                <span class="inline-flex items-center justify-center w-8 h-8 text-sm text-gray-400">…</span>
              <% end %>
            <% end %>
            <% if @pagy.next %>
              <%= link_to orders_path(page: @pagy.next), class: "inline-flex items-center justify-center w-8 h-8 rounded-md border border-gray-300 bg-white text-gray-500 hover:bg-pink-50 hover:border-pink-300 hover:text-pink-600 transition-colors" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              <% end %>
            <% else %>
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-md border border-gray-200 bg-gray-100 text-gray-300 cursor-not-allowed">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            <% end %>
          </nav>
        </div>
      <% end %>
    </div>

  <% else %>
    <div class="text-center py-16 bg-white rounded-xl border border-gray-200 shadow-sm">
      <svg class="mx-auto h-10 w-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
      </svg>
      <h3 class="text-sm font-semibold text-gray-900">No orders yet</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by browsing the catalog.</p>
      <div class="mt-4">
        <%= link_to "Browse Catalog", catalogs_path,
            class: "inline-flex items-center px-4 py-2 bg-pink-600 hover:bg-pink-700 text-white text-sm font-medium rounded-lg transition-colors" %>
      </div>
    </div>
  <% end %>
</div>
