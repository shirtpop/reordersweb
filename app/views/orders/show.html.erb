<!-- app/views/orders/show.html.erb -->
<div class="container mx-auto px-4 py-8" data-controller="order-show">
  <!-- Header Section -->
  <div class="mb-8">
    <!-- Breadcrumb -->
    <nav class="flex mb-6" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-2">
        <li class="inline-flex items-center">
          <%= link_to orders_path, class: "inline-flex items-center text-sm font-medium text-gray-600 hover:text-pink-600 transition-colors" do %>
            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Orders
          <% end %>
        </li>
      </ol>
    </nav>

    <!-- Order Header Card -->
    <div class="bg-gradient-to-r from-pink-600 to-rose-600 rounded-2xl shadow-xl p-8 text-white">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between">
        <div class="mb-4 lg:mb-0">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center">
              <span class="text-2xl font-bold">
                <%= @order.order_number.last(4) %>
              </span>
            </div>
            <div>
              <h1 class="text-3xl font-bold mb-1">
                <%= @order.order_number %>
              </h1>
              <p class="text-pink-100 text-sm">
                Placed on <%= @order.created_at.strftime("%B %d, %Y at %I:%M %p") %>
              </p>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <% if @order.received? %>
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-500 rounded-lg font-semibold shadow-lg">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Received
            </div>
          <% elsif @order.status_processing? %>
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-500 rounded-lg font-semibold shadow-lg">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
              Processing
            </div>
          <% elsif @order.status_submitted? %>
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-yellow-500 rounded-lg font-semibold shadow-lg">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Submitted
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Order Items -->
      <div class="bg-white rounded-xl shadow-md border-2 border-gray-200 overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-gray-50 to-gray-100 px-6 py-4 border-b-2 border-gray-200">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-bold text-gray-900">Order Items</h2>
            <div class="flex items-center gap-4">
              <div class="text-sm bg-white px-4 py-2 rounded-lg shadow-sm border border-gray-200">
                <span class="font-semibold text-pink-600"><%= @order.total_quantity || 0 %></span>
                <span class="text-gray-600"> items</span>
              </div>
              <div class="text-sm bg-white px-4 py-2 rounded-lg shadow-sm border border-gray-200">
                <span class="font-semibold text-pink-600"><%= @order.order_items.group_by(&:product_id).count %></span>
                <span class="text-gray-600"> products</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Items List -->
        <div class="p-6 space-y-6">
          <% @order.order_items.group_by(&:product_id).each do |_, item_group| %>
            <div class="border-2 border-gray-200 rounded-xl overflow-hidden hover:border-pink-300 transition-colors">
              <!-- Product Header -->
              <div class="bg-gradient-to-r from-pink-50 to-rose-50 p-4 border-b border-gray-200">
                <div class="flex items-start gap-4">
                  <% if item_group.first.product&.drive_files.any? %>
                    <div class="flex-shrink-0">
                      <%= image_tag item_group.first.product.drive_files.first.preview_url,
                          alt: item_group.first.product.name,
                          class: "w-20 h-20 object-cover rounded-lg shadow-md border-2 border-white",
                          referrerpolicy: "no-referrer" %>
                    </div>
                  <% else %>
                    <div class="flex-shrink-0 w-20 h-20 bg-gradient-to-br from-pink-200 to-rose-200 rounded-lg shadow-md border-2 border-white flex items-center justify-center">
                      <svg class="w-10 h-10 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                      </svg>
                    </div>
                  <% end %>

                  <div class="flex-grow">
                    <h3 class="text-lg font-bold text-gray-900 mb-1">
                      <%= item_group.first.product&.name || "Unknown Product" %>
                    </h3>
                    <% if item_group.first.product&.description.present? %>
                      <p class="text-sm text-gray-600 mb-2"><%= item_group.first.product.description %></p>
                    <% end %>

                    <div class="flex items-center gap-3 text-xs">
                      <span class="inline-flex items-center gap-1 px-2 py-1 bg-white rounded-md shadow-sm">
                        <span class="text-gray-500">ID:</span>
                        <span class="font-semibold text-gray-900">#<%= item_group.first.product&.id || 'N/A' %></span>
                      </span>
                      <span class="inline-flex items-center gap-1 px-2 py-1 bg-pink-600 text-white rounded-md shadow-sm">
                        <span class="font-semibold"><%= item_group.sum(&:quantity) %></span>
                        <span>total</span>
                      </span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Items by Color & Size -->
              <div class="p-4 bg-white">
                <div class="space-y-4">
                  <% item_group.group_by(&:color).each do |color, color_items| %>
                    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                      <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                          <div class="w-4 h-4 rounded-full border-2 border-gray-300" style="background-color: <%= color %>"></div>
                          <span class="font-bold text-gray-900"><%= color.humanize %></span>
                        </div>
                        <span class="px-3 py-1 bg-pink-100 text-pink-800 rounded-full text-sm font-semibold">
                          <%= color_items.sum(&:quantity) %> pieces
                        </span>
                      </div>

                      <!-- Size Grid -->
                      <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 gap-2">
                        <% color_items.each do |item| %>
                          <div class="bg-white rounded-lg px-3 py-2.5 text-center border-2 border-gray-200 hover:border-pink-300 transition-colors">
                            <div class="text-xs font-semibold text-gray-600 mb-0.5"><%= item.size %></div>
                            <div class="text-lg font-bold text-pink-600"><%= item.quantity %></div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Quick Actions -->
      <div class="bg-white rounded-xl shadow-md border-2 border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-gray-50 to-gray-100 px-6 py-4 border-b-2 border-gray-200">
          <h3 class="text-lg font-bold text-gray-900">Quick Actions</h3>
        </div>
        <div class="p-6 space-y-3">
          <!-- Order Again Button -->
          <%= button_to duplicate_order_path(@order),
              method: :post,
              class: "w-full inline-flex items-center justify-center gap-2 px-5 py-3 bg-gradient-to-r from-pink-600 to-rose-600 rounded-lg font-bold text-white hover:from-pink-700 hover:to-rose-700 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200",
              data: {
                turbo_confirm: "Add all items from this order to your cart?"
              } do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
            Order Again
          <% end %>

          <!-- Receipt actions (inventory updates only when inventory is enabled for the client) -->
          <% if @order.status_processing? && !@order.received? %>
            <%= button_to "Mark as Received",
                received_order_path(@order),
                method: :post,
                class: "w-full inline-flex items-center justify-center gap-2 px-5 py-3 bg-white border-2 border-green-600 rounded-lg font-bold text-green-600 hover:bg-green-50 shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200",
                data: {
                  turbo_confirm: @current_client.inventory_enabled? ? "Are you sure you want to mark this order as received? This will update the inventory." : "Are you sure you want to mark this order as received?"
                } %>
            <% if @current_client.inventory_enabled? %>
              <p class="text-xs text-gray-500 text-center mt-1">
                This will update the inventory
              </p>
            <% end %>
          <% elsif @order.status_submitted? %>
            <div class="w-full px-5 py-3 bg-yellow-50 border-2 border-yellow-300 rounded-lg">
              <div class="flex items-start gap-2">
                <svg class="w-5 h-5 text-yellow-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <p class="text-sm font-bold text-yellow-800">Order Submitted</p>
                  <p class="text-xs text-yellow-700 mt-1">
                    Your order has been submitted and is awaiting processing. You'll be able to mark it as received once it's being processed.
                  </p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="bg-white rounded-xl shadow-md border-2 border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-gray-50 to-gray-100 px-6 py-4 border-b-2 border-gray-200">
          <h3 class="text-lg font-bold text-gray-900">Order Summary</h3>
        </div>
        <div class="p-6 space-y-4">
          <div class="flex justify-between items-center py-2 border-b border-gray-100">
            <span class="text-sm font-medium text-gray-600">Order ID</span>
            <span class="text-sm font-bold text-gray-900"><%= @order.order_number %></span>
          </div>

          <div class="flex justify-between items-start py-2 border-b border-gray-100">
            <span class="text-sm font-medium text-gray-600">Ordered by</span>
            <span class="text-sm font-bold text-gray-900 text-right"><%= @order.ordered_by&.email || "Unknown User" %></span>
          </div>

          <div class="flex justify-between items-center py-2 border-b border-gray-100">
            <span class="text-sm font-medium text-gray-600">Total Items</span>
            <span class="px-3 py-1 bg-pink-100 text-pink-800 rounded-full text-sm font-bold">
              <%= @order.total_quantity || 0 %>
            </span>
          </div>

          <div class="flex justify-between items-center py-2">
            <span class="text-sm font-medium text-gray-600">Products</span>
            <span class="px-3 py-1 bg-pink-100 text-pink-800 rounded-full text-sm font-bold">
              <%= @order.order_items.group_by(&:product_id).count %>
            </span>
          </div>
        </div>
      </div>

      <!-- Delivery Information -->
      <div class="bg-white rounded-xl shadow-md border-2 border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-gray-50 to-gray-100 px-6 py-4 border-b-2 border-gray-200">
          <h3 class="text-lg font-bold text-gray-900">Delivery Information</h3>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Delivery Date</label>
            <div class="flex items-center gap-2 text-gray-900">
              <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <p class="font-bold"><%= @order.delivery_date&.strftime("%B %d, %Y") || "Not set" %></p>
            </div>
          </div>

          <div class="pt-4 border-t border-gray-200">
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Order Date</label>
            <div class="flex items-center gap-2 text-gray-900">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <p class="font-bold"><%= @order.created_at.strftime("%B %d, %Y") %></p>
                <p class="text-xs text-gray-500"><%= @order.created_at.strftime("%I:%M %p") %></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>