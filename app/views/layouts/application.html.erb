<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Reordersweb" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags 'client_application' %>
    <style>
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .marquee {
        display: flex;
        overflow: hidden;
        white-space: nowrap;
      }
      .marquee-content {
        display: flex;
        align-items: center;
        gap: 1rem;
        animation: marquee 20s linear infinite;
      }
      .marquee-item {
        flex-shrink: 0;
      }
      @keyframes slide-in-right {
        from {
          transform: translateX(100%);
          opacity: 0;
        }
        to {
          transform: translateX(0);
          opacity: 1;
        }
      }
      @keyframes fade-out {
        from {
          opacity: 1;
        }
        to {
          opacity: 0;
        }
      }
      .animate-slide-in-right {
        animation: slide-in-right 0.3s ease-out;
      }
      .animate-fade-out {
        animation: fade-out 0.3s ease-out;
      }
    </style>
  </head>

  <body class="client-theme bg-gray-50 min-h-screen flex flex-col">
    <!-- Navigation with Flowbite Navbar -->
    <nav class="sticky top-0 z-50 bg-gradient-to-r from-white via-pink-50 to-white border-b-2 border-pink-100 shadow-lg backdrop-blur-md bg-white/95">
      <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
        <!-- Logo and Brand -->
        <div class="flex items-center gap-3">
          <% if @current_client&.drive_files&.any? %>
            <!-- Static Logos -->
            <div class="flex items-center gap-2">
              <%= image_tag @current_client.drive_files.first.preview_url, 
                  alt: @current_client.company_name, 
                  class: "h-8 w-8 object-contain rounded-lg",
                  referrerpolicy: "no-referrer" %>
              <span class="text-gray-400 text-lg">×</span>
              <%= image_tag asset_path("pink-logo.svg"), 
                  alt: "Shirtpop", 
                  class: "h-8 object-contain" %>
            </div>
            <!-- Marquee: Text Only -->
            <div class="marquee max-w-xs h-10">
              <div class="marquee-content">
                <div class="marquee-item flex items-center gap-2">
                  <span class="text-2xl font-semibold whitespace-nowrap text-gray-900"><%= @current_client.company_name %></span>
                  <span class="text-gray-400 text-lg">×</span>
                  <span class="text-2xl font-semibold whitespace-nowrap text-gray-900">Shirtpop</span>
                </div>
                <!-- Duplicate for seamless loop -->
                <div class="marquee-item flex items-center gap-2">
                  <span class="text-2xl font-semibold whitespace-nowrap text-gray-900"><%= @current_client.company_name %></span>
                  <span class="text-gray-400 text-lg">×</span>
                  <span class="text-2xl font-semibold whitespace-nowrap text-gray-900">Shirtpop</span>
                </div>
              </div>
            </div>
          <% else %>
            <!-- Shirtpop Logo Only -->
            <%= image_tag asset_path("pink-logo.svg"), 
                alt: "Shirtpop", 
                class: "h-8 object-contain" %>
            <span class="self-center text-2xl font-semibold whitespace-nowrap text-gray-900">Shirtpop</span>
          <% end %>
        </div>

        <!-- User Menu and Mobile Menu Button -->
        <div class="flex items-center md:order-2 space-x-3 md:space-x-0 rtl:space-x-reverse">
          <!-- User Dropdown Button -->
          <button type="button" class="flex text-sm bg-gray-800 rounded-full md:me-0 focus:ring-4 focus:ring-pink-300" id="user-menu-button" aria-expanded="false" data-dropdown-toggle="user-dropdown" data-dropdown-placement="bottom">
            <span class="sr-only">Open user menu</span>
            <div class="w-8 h-8 bg-pink-600 rounded-full flex items-center justify-center">
              <span class="text-white text-sm font-medium"><%= current_user.email.first.upcase %></span>
            </div>
          </button>
          
          <!-- User Dropdown -->
          <div class="z-50 hidden my-4 text-base list-none bg-white divide-y divide-gray-100 rounded-lg shadow" id="user-dropdown">
            <div class="px-4 py-3">
              <span class="block text-sm text-gray-900">Hello,</span>
              <span class="block text-sm text-gray-500 truncate"><%= current_user.email.split('@').first.capitalize %></span>
            </div>
            <ul class="py-2" aria-labelledby="user-menu-button">
              <li>
                <%= link_to "Change password", edit_user_registration_path, 
                            class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
              </li>
              <li>
                <%= link_to "Sign out", destroy_user_session_path, 
                            data: { "turbo-method": :delete },
                            class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
              </li>
            </ul>
          </div>

          <!-- Mobile menu button -->
          <button data-collapse-toggle="navbar-user" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200" aria-controls="navbar-user" aria-expanded="false">
            <span class="sr-only">Open main menu</span>
            <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
            </svg>
          </button>
        </div>

        <!-- Navigation Links -->
        <div class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1" id="navbar-user">
          <ul class="flex flex-col font-medium p-4 md:p-0 mt-4 border border-gray-100 rounded-lg bg-gray-50 md:space-x-8 rtl:space-x-reverse md:flex-row md:mt-0 md:border-0 md:bg-white">
            <li>
              <%= link_to "Shop", storefront_path,
                          class: "#{current_page?(storefront_path) || current_page?(root_path) ? 'block py-2 px-3 text-pink-800 md:text-pink-700 md:p-0 rounded-lg' : 'block py-2 px-3 text-gray-900 rounded-lg transition-all duration-200 hover:bg-gradient-to-r hover:from-pink-50 hover:to-rose-50 md:hover:bg-transparent md:hover:text-pink-700 md:hover:scale-105 md:p-0'}" %>
            </li>
            <li>
              <%= link_to "Orders", orders_path,
                          class: "#{current_page?(orders_path) ? 'block py-2 px-3 text-pink-800 rounded-lg md:text-pink-700 md:p-0' : 'block py-2 px-3 text-gray-900 rounded-lg transition-all duration-200 hover:bg-gradient-to-r hover:from-pink-50 hover:to-rose-50 md:hover:bg-transparent md:hover:text-pink-700 md:hover:scale-105 md:p-0'}" %>
            </li>
            <% if client_inventory_enabled? %>
              <li>
                <%= link_to "Inventories", inventories_path,
                            class: "#{current_page?(inventories_path) ? 'block py-2 px-3 text-pink-800 rounded-lg md:text-pink-700 md:p-0' : 'block py-2 px-3 text-gray-900 rounded-lg transition-all duration-200 hover:bg-gradient-to-r hover:from-pink-50 hover:to-rose-50 md:hover:bg-transparent md:hover:text-pink-700 md:hover:scale-105 md:p-0'}" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Flash Messages with Flowbite Alerts -->
    <% if notice %>
      <div id="alert-success" class="flex items-center p-4 mb-4 bg-gradient-to-r from-green-50 to-emerald-50 border-2 border-green-200 text-green-800 rounded-xl shadow-lg animate-slide-in-right" role="alert">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center shadow-md">
          <svg class="w-5 h-5 text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
          </svg>
        </div>
        <span class="sr-only">Success</span>
        <div class="ms-3 text-sm font-medium">
          <%= notice %>
        </div>
        <button type="button" class="ms-auto -mx-1.5 -my-1.5 bg-green-50 text-green-500 rounded-lg focus:ring-2 focus:ring-green-400 p-1.5 hover:bg-green-200 inline-flex items-center justify-center h-8 w-8" data-dismiss-target="#alert-success" aria-label="Close">
          <span class="sr-only">Close</span>
          <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
          </svg>
        </button>
      </div>
    <% end %>

    <% if alert %>
      <div id="alert-error" class="flex items-center p-4 mb-4 bg-gradient-to-r from-red-50 to-rose-50 border-2 border-red-200 text-red-800 rounded-xl shadow-lg animate-slide-in-right" role="alert">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-red-500 to-rose-600 flex items-center justify-center shadow-md">
          <svg class="w-5 h-5 text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
          </svg>
        </div>
        <span class="sr-only">Error</span>
        <div class="ms-3 text-sm font-medium">
          <%= alert %>
        </div>
        <button type="button" class="ms-auto -mx-1.5 -my-1.5 bg-red-50 text-red-500 rounded-lg focus:ring-2 focus:ring-red-400 p-1.5 hover:bg-red-200 inline-flex items-center justify-center h-8 w-8" data-dismiss-target="#alert-error" aria-label="Close">
          <span class="sr-only">Close</span>
          <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
          </svg>
        </button>
      </div>
    <% end %>

    <!-- Turbo Stream Flash Messages Container -->
    <div id="flash-messages" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"></div>

    <main class="flex-1 w-full">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Brand Column -->
          <div class="col-span-1 md:col-span-2">
            <div class="flex items-center gap-3 mb-4">
              <%= image_tag asset_path("pink-logo.svg"), class: "h-10 w-auto" %>
              <span class="text-2xl font-bold bg-gradient-to-r from-pink-400 to-rose-400 bg-clip-text text-transparent">Shirtpop</span>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed max-w-md">
              Your trusted partner for custom apparel and reordering solutions.
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider mb-4 text-pink-400">Quick Links</h3>
            <ul class="space-y-2">
              <li><%= link_to "Shop", storefront_path, class: "text-gray-400 hover:text-pink-400 transition-colors duration-200 text-sm" %></li>
              <li><%= link_to "Orders", orders_path, class: "text-gray-400 hover:text-pink-400 transition-colors duration-200 text-sm" %></li>
              <li><%= link_to "Cart", cart_path, class: "text-gray-400 hover:text-pink-400 transition-colors duration-200 text-sm" %></li>
            </ul>
          </div>

          <!-- Support -->
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider mb-4 text-pink-400">Support</h3>
            <p class="text-gray-400 text-sm">Contact your account manager for assistance</p>
          </div>
        </div>

        <!-- Bottom Bar -->
        <div class="border-t border-gray-700 mt-8 pt-8 text-center">
          <p class="text-gray-500 text-sm">© <%= Date.current.year %> Shirtpop. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>