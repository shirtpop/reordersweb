<div class="container mx-auto px-4 py-8 max-w-6xl">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Shopping Cart</h1>

  <% if @sorted_items.empty? %>
    <!-- Empty Cart State -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 text-center py-20">
      <svg class="w-24 h-24 mx-auto text-gray-300 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
      </svg>
      <h3 class="text-2xl font-semibold text-gray-700 mb-3">Your cart is empty</h3>
      <p class="text-gray-500 mb-8 text-lg">Add some products to get started!</p>
      <%= link_to "Continue Shopping", storefront_path, class: "inline-block bg-pink-600 hover:bg-pink-700 text-white font-semibold px-8 py-4 rounded-lg transition-colors shadow-md text-lg" %>
    </div>

  <% else %>
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Cart Items (Left Column) -->
      <div class="lg:col-span-2 space-y-4">
        <% @sorted_items.group_by(&:product).each do |product, items| %>
          <div class="bg-white rounded-2xl shadow-md hover:shadow-xl border-2 border-gray-200 hover:border-pink-300 p-6 transition-all duration-300 transform hover:-translate-y-1">
            <div class="flex gap-6">
              <!-- Product Image with Glow Ring -->
              <div class="flex-shrink-0 relative group">
                <% if product.drive_files.any? %>
                  <%= image_tag product.drive_files.first.preview_url,
                      alt: product.name,
                      class: "w-36 h-36 object-cover rounded-xl border-2 border-gray-200 shadow-lg group-hover:shadow-2xl transition-shadow duration-300",
                      referrerpolicy: "no-referrer" %>
                  <div class="absolute -inset-1 bg-gradient-to-r from-pink-600 to-rose-600 rounded-xl opacity-0 group-hover:opacity-20 blur-lg transition-opacity duration-300 -z-10"></div>
                <% else %>
                  <div class="w-36 h-36 bg-gray-100 rounded-xl flex items-center justify-center border-2 border-gray-200">
                    <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                  </div>
                <% end %>
              </div>

              <!-- Product Details -->
              <div class="flex-grow">
                <div class="flex justify-between items-start mb-3">
                  <h3 class="text-xl font-bold text-gray-900 group-hover:text-pink-700 transition-colors"><%= product.name %></h3>
                  <%= button_to cart_item_path(product), method: :delete,
                      class: "p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors duration-200",
                      title: "Remove product from cart",
                      data: { turbo_confirm: "Remove all #{product.name} items from your cart?" } do %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  <% end %>
                </div>

                <!-- Minimum order summary -->
                <% color_minimums = product.product_colors.select { |pc| pc.minimum_order.to_i > 0 } %>
                <% if product.minimum_order.to_i > 0 || color_minimums.any? %>
                  <div class="mb-3 flex flex-wrap gap-2 items-center">
                    <% if product.minimum_order.to_i > 0 %>
                      <span class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-700 bg-indigo-50 border border-indigo-200 rounded-full px-2.5 py-1">
                        Min. total: <%= product.minimum_order %> units
                      </span>
                    <% end %>
                    <% color_minimums.each do |pc| %>
                      <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-700 bg-amber-50 border border-amber-200 rounded-full px-2.5 py-1">
                        <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background-color: <%= pc.hex_color %>"></span>
                        <%= pc.name.capitalize %>: min <%= pc.minimum_order %>
                      </span>
                    <% end %>
                  </div>
                <% end %>

                <!-- Item Variants -->
                <div class="space-y-2">
                  <% items.each do |item| %>
                    <%= render "cart_items/item", item: item, product: product, cart: @cart %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Order Summary (Right Column - Sticky) -->
      <div class="lg:col-span-1">
        <%= render "cart/order_summary", cart: @cart, calculator: @calculator %>
      </div>
    </div>

    <%= render "cart/mobile_summary", cart: @cart, calculator: @calculator %>
  <% end %>
</div>
