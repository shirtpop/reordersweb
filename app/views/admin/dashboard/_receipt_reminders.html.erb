<% if pending_receipt_orders.any? %>
  <div class="w-full p-4 bg-amber-50 border border-amber-200 rounded-lg shadow dark:bg-amber-900/20 dark:border-amber-700">
    <div class="flex items-start mb-3">
      <svg class="w-5 h-5 text-amber-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
      </svg>
      <div class="ml-3">
        <h3 class="text-sm font-semibold text-amber-800 dark:text-amber-300">Orders Pending Receipt</h3>
        <p class="text-xs text-amber-600 dark:text-amber-400 mt-0.5">
          <%= pending_receipt_orders.size %> order(s) past delivery date without receipt confirmation
        </p>
      </div>
    </div>
    <ul class="space-y-2">
      <% pending_receipt_orders.each do |order| %>
        <li class="flex items-center justify-between bg-white dark:bg-gray-800 rounded-md px-3 py-2 border border-amber-100 dark:border-amber-800">
          <div class="flex items-center space-x-3">
            <span class="text-sm font-medium text-gray-900 dark:text-white">
              <%= link_to "##{order.id}", admin_order_path(order), class: "text-blue-600 hover:underline dark:text-blue-400" %>
            </span>
            <span class="text-sm text-gray-600 dark:text-gray-400"><%= order.client.company_name %></span>
          </div>
          <div class="flex items-center space-x-3">
            <span class="text-xs text-amber-600 dark:text-amber-400">
              Due: <%= order.delivery_date&.strftime("%b %d, %Y") %>
            </span>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-300">
              <%= distance_of_time_in_words(order.delivery_date, Date.current) %> overdue
            </span>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
