<div class="space-y-6">
  <!-- Header -->
  <div class="md:flex md:items-center md:justify-between">
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">Order Dashboard</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Track order trends and fulfillment status</p>
    </div>
    <div class="mt-4 flex md:mt-0 md:ml-4">
      <%= link_to "View All Orders", admin_orders_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-blue-500 dark:hover:bg-blue-600" %>
    </div>
  </div>

  <!-- Receipt Reminders -->
  <%= render "admin/dashboard/receipt_reminders", pending_receipt_orders: @pending_receipt_orders %>

  <!-- Metrics Row -->
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
    <%= render Admin::MetricCardComponent.new(
      title: "Today vs Yesterday",
      value: @orders_today,
      comparison: {
        previous: @orders_yesterday,
        change: @orders_today - @orders_yesterday,
        percent: calculate_percent_change(@orders_yesterday, @orders_today)
      },
      color: "blue",
      icon: "calendar"
    ) %>

    <%= render Admin::MetricCardComponent.new(
      title: "This Week vs Last",
      value: @orders_this_week,
      comparison: {
        previous: @orders_last_week,
        change: @orders_this_week - @orders_last_week,
        percent: calculate_percent_change(@orders_last_week, @orders_this_week)
      },
      color: "purple",
      icon: "trending"
    ) %>

    <%= render Admin::MetricCardComponent.new(
      title: "Pending Fulfillment",
      value: @pending_fulfillment_count,
      color: "amber",
      icon: "clock"
    ) %>

    <%= render Admin::MetricCardComponent.new(
      title: "Processing Orders",
      value: @orders_by_status["processing"] || 0,
      color: "green",
      icon: "cog"
    ) %>
  </div>

  <!-- Order Trend Chart -->
  <div class="w-full p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700"
       data-controller="order-chart"
       data-order-chart-data-value="<%= @daily_order_counts.to_json %>"
       data-order-chart-range-value="7">
    <div class="mb-4 flex items-center justify-between">
      <div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Order Volume Trend</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">Daily order count over time</p>
      </div>

      <!-- Date Range Filter -->
      <div class="flex items-center space-x-2">
        <button data-action="click->order-chart#changeRange"
                data-range="7"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors
                       text-white bg-blue-600 border-blue-600
                       dark:bg-blue-500 dark:border-blue-500">
          7D
        </button>
        <button data-action="click->order-chart#changeRange"
                data-range="30"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors
                       text-gray-700 bg-white border-gray-300 hover:bg-gray-50
                       dark:text-gray-300 dark:bg-gray-700 dark:border-gray-600 dark:hover:bg-gray-600">
          30D
        </button>
        <button data-action="click->order-chart#changeRange"
                data-range="90"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors
                       text-gray-700 bg-white border-gray-300 hover:bg-gray-50
                       dark:text-gray-300 dark:bg-gray-700 dark:border-gray-600 dark:hover:bg-gray-600">
          3M
        </button>
        <button data-action="click->order-chart#changeRange"
                data-range="180"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors
                       text-gray-700 bg-white border-gray-300 hover:bg-gray-50
                       dark:text-gray-300 dark:bg-gray-700 dark:border-gray-600 dark:hover:bg-gray-600">
          6M
        </button>
        <button data-action="click->order-chart#changeRange"
                data-range="365"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors
                       text-gray-700 bg-white border-gray-300 hover:bg-gray-50
                       dark:text-gray-300 dark:bg-gray-700 dark:border-gray-600 dark:hover:bg-gray-600">
          1Y
        </button>
      </div>
    </div>

    <div data-order-chart-target="chart"
         class="w-full h-[300px]">
    </div>
  </div>

  <!-- Recent Orders -->
  <%= render "admin/dashboard/recent_orders", recent_orders: @recent_orders %>
</div>
