<% active_tab = params[:tab] == "images" ? 1 : 0 %>

<div class="bg-white dark:bg-gray-900 min-h-screen">
  <!-- Header -->
  <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div class="flex items-center space-x-4">
          <%= link_to admin_products_path,
              class: "text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 transition-colors" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          <% end %>
          <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @product.name %></h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Product Details</p>
          </div>
        </div>
        <div class="flex items-center space-x-3">
          <%= link_to "Edit Product", edit_admin_product_path(@product),
              class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors" %>
          <%= button_to "Duplicate", duplicate_admin_product_path(@product), method: :post,
              form: { data: { turbo: false } },
              confirm: "Are you sure you want to duplicate this product?",
              class: "px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 transition-colors" %>
          <%= button_to "Delete", admin_product_path(@product), method: :delete,
              form: { data: { turbo: false } },
              confirm: "Are you sure you want to delete this product?",
              class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 transition-colors" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div data-controller="tabs" data-tabs-active-value="<%= active_tab %>">
    <!-- Tab bar -->
    <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="flex space-x-1" aria-label="Product tabs">
          <button data-tabs-target="tab"
                  data-action="click->tabs#switch"
                  class="px-5 py-4 text-sm border-b-2 transition-colors whitespace-nowrap">
            Overview
          </button>
          <button data-tabs-target="tab"
                  data-action="click->tabs#switch"
                  class="px-5 py-4 text-sm border-b-2 transition-colors whitespace-nowrap">
            Color Images
            <% color_count = @product.product_colors.size %>
            <% if color_count > 0 %>
              <span class="ml-1.5 inline-flex items-center justify-center px-1.5 py-0.5 text-xs rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
                <%= color_count %>
              </span>
            <% end %>
          </button>
        </nav>
      </div>
    </div>

    <!-- Overview Panel -->
    <div data-tabs-target="panel">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Main Content -->
          <div class="lg:col-span-2 space-y-8">

            <% if @product.description.present? %>
              <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Description</h2>
                <div class="prose-content text-gray-700 dark:text-gray-300 trix-content">
                  <%= @product.description %>
                </div>
              </div>
            <% end %>

            <% if @product.sizes.present? %>
              <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Available Sizes</h2>
                <div class="flex flex-wrap gap-2">
                  <% @product.sizes.each do |size| %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                      <%= size %>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>

            <!-- Default Product Images -->
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Default Images</h2>
              <%= render "shared/image_uploader", attachable: @product %>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="space-y-6">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Product Information</h2>
              <dl class="space-y-4">
                <div>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Product Name</dt>
                  <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @product.name %></dd>
                </div>
                <% if @product.created_at %>
                  <div>
                    <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Created</dt>
                    <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                      <%= @product.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                    </dd>
                  </div>
                <% end %>
                <% if @product.updated_at && @product.updated_at != @product.created_at %>
                  <div>
                    <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Last Updated</dt>
                    <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                      <%= @product.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
                    </dd>
                  </div>
                <% end %>
              </dl>
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Pricing</h2>
              <div class="space-y-4">
                <div class="flex justify-between items-center p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
                  <div>
                    <p class="text-sm font-medium text-blue-900 dark:text-blue-200">Base Price</p>
                    <p class="text-xs text-blue-700 dark:text-blue-300">Minimum order: <%= @product.minimum_order || 'Not specified' %></p>
                  </div>
                  <p class="text-xl font-bold text-blue-600 dark:text-blue-400">
                    <%= @product.base_price || 'Not specified' %>
                  </p>
                </div>
                <% if @product.bulk_prices.present? && @product.bulk_prices.any? %>
                  <div>
                    <h3 class="text-sm font-medium text-gray-900 dark:text-white mb-2">Bulk Pricing</h3>
                    <div class="space-y-2">
                      <% Array(@product.bulk_prices).each do |bulk_price| %>
                        <div class="flex justify-between items-center p-2 bg-gray-50 dark:bg-gray-700 rounded">
                          <span class="text-sm text-gray-600 dark:text-gray-300"><%= bulk_price['qty'] %>+ units</span>
                          <span class="text-sm font-medium text-gray-900 dark:text-white"><%= bulk_price['price'] %></span>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% else %>
                  <p class="text-sm text-gray-500 dark:text-gray-400 italic text-center py-4">No bulk pricing tiers</p>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Color Images Panel -->
    <div data-tabs-target="panel" class="hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <% colors = @product.product_colors.includes(:product_color_images) %>
        <% if colors.any? %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
            <!-- Color sub-tabs -->
            <div data-controller="tabs"
                 class="flex flex-col">
              <div class="border-b border-gray-200 dark:border-gray-700 px-6 pt-4 overflow-x-auto">
                <nav class="flex space-x-1 min-w-max">
                  <% colors.each_with_index do |color, i| %>
                    <button data-tabs-target="tab"
                            data-action="click->tabs#switch"
                            class="inline-flex items-center gap-2 px-4 py-3 text-sm border-b-2 transition-colors whitespace-nowrap">
                      <% if color.hex_color.present? %>
                        <span class="inline-block w-3 h-3 rounded-full border border-gray-200 dark:border-gray-600 flex-shrink-0"
                              style="background-color: <%= color.hex_color %>"></span>
                      <% end %>
                      <%= color.name %>
                    </button>
                  <% end %>
                </nav>
              </div>

              <!-- Per-color panels -->
              <% colors.each do |color| %>
                <div data-tabs-target="panel" class="hidden p-6">
                  <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-3">
                      <% if color.hex_color.present? %>
                        <span class="inline-block w-5 h-5 rounded-full border border-gray-200 dark:border-gray-600"
                              style="background-color: <%= color.hex_color %>"></span>
                      <% end %>
                      <h3 class="text-base font-semibold text-gray-900 dark:text-white"><%= color.name %></h3>
                    </div>
                    <span class="text-xs text-gray-400 dark:text-gray-500">Upload one image per angle</span>
                  </div>

                  <% images = color.product_color_images %>
                  <% if images.any? %>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                      <% images.each do |color_image| %>
                        <%= render "admin/products/color_image_slot", color_image: color_image %>
                      <% end %>
                    </div>
                  <% else %>
                    <div class="text-center py-12 text-gray-400 dark:text-gray-500">
                      <p class="text-sm">No image slots found. Re-save this color to initialize them.</p>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-12 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
            <p class="text-sm font-medium text-gray-900 dark:text-white mb-1">No colors defined yet</p>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Add colors to this product to manage their images.</p>
            <%= link_to "Edit Product to Add Colors", edit_admin_product_path(@product),
                class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-colors" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
