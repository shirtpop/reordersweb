<div class="p-6 bg-white dark:bg-gray-800 rounded-lg shadow-sm">
  <!-- Header Section -->
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center space-x-4">
      <!-- Back Button -->
      <%= link_to admin_orders_path, 
          class: "inline-flex items-center px-3 py-2 text-sm font-medium text-gray-500 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Orders
      <% end %>

      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= @order.catalog.name %></h1>
        <div class="flex items-center mt-2 space-x-4">
          <!-- Created Date -->
          <span class="text-sm text-gray-500 dark:text-gray-400">
            Created <%= @order.created_at.strftime("%B %d, %Y") %>
          </span>
          <!-- Order ID -->
          <span class="text-sm text-gray-500 dark:text-gray-400">
            <%= @order.order_number %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column - Order Details & Items -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Order Summary Card -->
      <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Order Summary</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Client Name</label>
            <p class="mt-1 text-sm text-gray-900 dark:text-white"><%= @order.client.company_name %></p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Ordered by</label>
            <p class="mt-1 text-sm text-gray-900 dark:text-white"><%= @order.ordered_by&.email || "Unknown User" %></p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Delivery Date</label>
            <p class="mt-1 text-sm text-gray-900 dark:text-white">
              <%= @order.delivery_date&.strftime("%B %d, %Y") %>
            </p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Total Estimation Price</label>
            <p class="mt-1 text-lg font-semibold text-green-600 dark:text-green-400">
              $<%= number_with_precision(@order.price, precision: 2) %>
            </p>
          </div>
        </div>
      </div>

      <!-- Order Items Card -->
      <div class="bg-white dark:bg-gray-700 rounded-lg shadow-sm border border-gray-200 dark:border-gray-600">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-600">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Order Items</h2>
          <p class="text-sm text-gray-500 dark:text-gray-400">
            <%= pluralize(@order.total_quantity, 'item') %> total
          </p>
        </div>
        
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                  Product
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                  Color
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                  Size
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                  Quantity
                </th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-700 divide-y divide-gray-200 dark:divide-gray-600">
              <% @order.order_items.each do |item| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-600">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900 dark:text-white">
                      <%= item.product.name %>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center">
                      <div class="w-4 h-4 rounded-full mr-2" style="background-color: <%= item.color %>"></div>
                      <span class="text-sm text-gray-900 dark:text-white capitalize">
                        <%= item.color %>
                      </span>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
                      <%= item.size %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                    <%= item.quantity %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Items Summary -->
        <div class="px-6 py-4 bg-gray-50 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-600">
          <div class="flex justify-between items-center">
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
              Total Items: <%= @order.total_quantity %>
            </span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
              Unique Products: <%= @order.order_items.group_by(&:product_id).count %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column - Status & Timeline -->
    <div class="space-y-6">
      <!-- Order Status & Actions Card -->
      <div class="bg-white dark:bg-gray-700 rounded-lg shadow-sm border border-gray-200 dark:border-gray-600 p-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Order Status</h3>

        <div class="mb-4">
          <% case @order.status %>
          <% when "submitted" %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Submitted
            </span>
          <% when "processing" %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
              Processing
            </span>
          <% when "received" %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Received
            </span>
          <% when "cancelled" %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              Cancelled
            </span>
          <% end %>
        </div>

        <!-- Action Buttons -->
        <% if @order.status_submitted? %>
          <%= button_to "Mark as Processing",
              mark_as_processing_admin_order_path(@order),
              method: :post,
              class: "w-full inline-flex items-center justify-center px-4 py-2 bg-blue-600 border border-transparent rounded-md font-semibold text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors",
              data: {
                turbo_confirm: "Mark this order as processing?"
              } %>
        <% end %>
      </div>

      <!-- Invoice URL Card -->
      <div class="bg-white dark:bg-gray-700 rounded-lg shadow-sm border border-gray-200 dark:border-gray-600 p-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Invoice</h3>
        <div data-controller="inline-edit">
          <!-- Display mode -->
          <div data-inline-edit-target="display" class="flex items-center space-x-2">
            <% if @order.invoice_url.present? %>
              <%= link_to @order.invoice_url, @order.invoice_url, target: "_blank", rel: "noopener noreferrer",
                  class: "text-sm text-blue-600 hover:underline dark:text-blue-400 truncate" %>
            <% else %>
              <span class="text-sm text-gray-400 dark:text-gray-500 italic">No invoice URL</span>
            <% end %>
            <button type="button" data-action="click->inline-edit#edit"
                    class="flex-shrink-0 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" title="Edit">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
              </svg>
            </button>
          </div>
          <!-- Edit mode -->
          <div data-inline-edit-target="form" class="hidden">
            <%= form_with url: admin_order_path(@order), method: :patch, class: "flex items-center space-x-2" do %>
              <input type="text" name="order[invoice_url]" value="<%= @order.invoice_url %>"
                     placeholder="https://..."
                     class="flex-1 px-2 py-1 text-sm border border-gray-300 rounded focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-600 dark:border-gray-500 dark:text-white dark:placeholder-gray-400">
              <button type="submit" class="text-green-600 hover:text-green-700 dark:text-green-400">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </button>
              <button type="button" data-action="click->inline-edit#cancel" class="text-gray-400 hover:text-gray-600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Quick Stats Card -->
      <div class="bg-white dark:bg-gray-700 rounded-lg shadow-sm border border-gray-200 dark:border-gray-600 p-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Quick Stats</h3>
        
        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-600 dark:text-gray-400">Days Until Delivery</span>
            <% if @order.delivery_date %>
              <span class="text-sm font-medium text-gray-900 dark:text-white">
                <%= (@order.delivery_date - Date.current).to_i %> days
              </span>
            <% else %>
              <span class="text-sm font-medium text-gray-900 dark:text-white">
                N/A
              </span>
            <% end %>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-600 dark:text-gray-400">Total Quantity</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white">
              <%= @order.total_quantity %> items
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-600 dark:text-gray-400">Product Types</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white">
              <%= @order.order_items.distinct.count(&:product_id) %>
            </span>
          </div>

          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-600 dark:text-gray-400">Sizes Available</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white">
              <%= @order.order_items.map(&:size).uniq.join(', ') %>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>