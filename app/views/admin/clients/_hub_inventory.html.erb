<div data-controller="collapsible-section" data-collapsible-section-open-value="false">
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
    <button type="button" data-action="click->collapsible-section#toggle"
            class="w-full px-6 py-4 flex items-center justify-between">
      <div class="flex items-center space-x-2">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Inventory</h3>
        <% if client.inventory_enabled? %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">Enabled</span>
        <% else %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-600 dark:text-gray-300">Disabled</span>
        <% end %>
      </div>
      <svg data-collapsible-section-target="icon" class="w-5 h-5 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </button>
    <div data-collapsible-section-target="content" class="p-6 border-t border-gray-200 dark:border-gray-700">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
        Inventory tracking is currently <strong><%= client.inventory_enabled? ? "enabled" : "disabled" %></strong> for this client.
        You can change this setting from the <%= link_to "edit page", edit_admin_client_path(client), class: "text-blue-600 hover:underline dark:text-blue-400" %>.
      </p>

      <% if client.inventory_enabled? %>
        <div class="mt-4">
          <div class="flex items-center justify-between mb-3">
            <h4 class="text-sm font-medium text-gray-900 dark:text-white">Recent Products</h4>
            <%= link_to "View all", admin_client_products_path(client),
                class: "text-sm text-blue-600 hover:underline dark:text-blue-400" %>
          </div>

          <% if recent_client_products.any? %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead>
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Name</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Shirtpop Product</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Variants</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Created</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"></th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                  <% recent_client_products.each do |product| %>
                    <tr>
                      <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white"><%= product.name %></td>
                      <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400"><%= product.product_id.nil? ? 'No' : 'Yes' %></td>
                      <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400"><%= product.product_variants_count %></td>
                      <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400"><%= product.created_at.strftime("%b %d, %Y") %></td>
                      <td class="px-4 py-3 text-right">
                        <%= link_to "View", admin_client_product_path(client, product),
                            class: "text-sm text-blue-600 hover:underline dark:text-blue-400" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-6">
              <p class="text-sm text-gray-500 dark:text-gray-400">No products yet.</p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
