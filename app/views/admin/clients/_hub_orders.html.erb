<div data-controller="collapsible-section" data-collapsible-section-open-value="true">
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
    <button type="button" data-action="click->collapsible-section#toggle"
            class="w-full px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <div class="flex items-center space-x-2">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Recent Orders</h3>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
          <%= recent_orders.size %>
        </span>
      </div>
      <svg data-collapsible-section-target="icon" class="w-5 h-5 text-gray-500 transition-transform duration-200 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </button>
    <div data-collapsible-section-target="content" class="p-6">
      <% if recent_orders.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead>
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Order</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Delivery</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Receipt</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              <% recent_orders.each do |order| %>
                <% overdue = order.delivery_date.present? && order.delivery_date < Date.current && !order.received? %>
                <tr class="<%= overdue ? 'bg-amber-50 dark:bg-amber-900/20' : '' %>">
                  <td class="px-4 py-3">
                    <%= link_to admin_order_path(order), class: "text-sm font-medium text-blue-600 hover:underline dark:text-blue-400" do %>
                      <%= order.order_number %>
                    <% end %>
                    <p class="text-xs text-gray-500 dark:text-gray-400"><%= order.created_at.strftime("%b %d, %Y") %></p>
                  </td>
                  <td class="px-4 py-3">
                    <% status_classes = case order.status
                      when "submitted" then "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300"
                      when "processing" then "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300"
                      when "received" then "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300"
                      when "cancelled" then "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300"
                      else "bg-gray-100 text-gray-800 dark:bg-gray-600 dark:text-gray-300"
                    end %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= status_classes %>">
                      <%= order.status.capitalize %>
                    </span>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-900 dark:text-white">
                    <%= order.delivery_date&.strftime("%b %d, %Y") || "N/A" %>
                  </td>
                  <td class="px-4 py-3">
                    <% if order.received? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">Received</span>
                    <% elsif overdue %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-300">Overdue</span>
                    <% else %>
                      <span class="text-xs text-gray-500 dark:text-gray-400">Pending</span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 text-sm text-right text-gray-900 dark:text-white font-medium">
                    <%= number_to_currency(order.price) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-6">
          <p class="text-sm text-gray-500 dark:text-gray-400">No orders yet.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
