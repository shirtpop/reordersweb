<%= turbo_frame_tag "hub-catalogs" do %>
  <div data-controller="collapsible-section" data-collapsible-section-open-value="true" class="pb-6">
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <button type="button" data-action="click->collapsible-section#toggle"
              class="w-full px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
        <div class="flex items-center space-x-2">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Catalogs</h3>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
            <%= catalogs.size %>
          </span>
        </div>
        <svg data-collapsible-section-target="icon" class="w-5 h-5 text-gray-500 transition-transform duration-200 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>
      <div data-collapsible-section-target="content" class="p-6 space-y-6">
        <% if catalogs.any? %>
          <% catalogs.each do |catalog| %>
            <div class="border border-gray-200 dark:border-gray-600 rounded-lg overflow-hidden">
              <!-- Catalog Header -->
              <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3">
                <div class="flex items-center justify-between">
                  <div class="flex items-center space-x-2 flex-1" data-controller="inline-edit">
                    <!-- Display mode -->
                    <div data-inline-edit-target="display" class="flex items-center space-x-2">
                      <h4 class="font-medium text-gray-900 dark:text-white"><%= catalog.name %></h4>
                      <button type="button" data-action="click->inline-edit#edit"
                              class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" title="Rename">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                        </svg>
                      </button>
                    </div>
                    <!-- Edit mode -->
                    <div data-inline-edit-target="form" class="hidden flex-1">
                      <%= form_with url: admin_client_catalog_path(client, catalog), method: :patch,
                          class: "flex items-center space-x-2",
                          data: { turbo_frame: "hub-catalogs" } do %>
                        <input type="text" name="catalog[name]" value="<%= catalog.name %>"
                               class="flex-1 px-2 py-1 text-sm border border-gray-300 rounded focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-600 dark:border-gray-500 dark:text-white" required>
                        <button type="submit" class="text-green-600 hover:text-green-700 dark:text-green-400">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                          </svg>
                        </button>
                        <button type="button" data-action="click->inline-edit#cancel" class="text-gray-400 hover:text-gray-600">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                          </svg>
                        </button>
                      <% end %>
                    </div>
                  </div>

                  <div class="flex items-center space-x-2 ml-3">
                    <% status_classes = case catalog.status
                      when "active" then "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300"
                      when "draft" then "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300"
                      when "archived" then "bg-gray-100 text-gray-800 dark:bg-gray-600 dark:text-gray-300"
                    end %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= status_classes %>">
                      <%= catalog.status.capitalize %>
                    </span>

                    <% unless catalog.active? %>
                      <%= button_to "Activate", admin_client_catalog_path(client, catalog), method: :patch,
                          params: { status: "active" },
                          class: "text-xs px-2 py-1 rounded text-green-600 bg-green-50 hover:bg-green-100 dark:text-green-400 dark:bg-green-900/30",
                          data: { turbo_frame: "hub-catalogs" } %>
                    <% end %>
                    <% if catalog.active? %>
                      <%= button_to "Archive", admin_client_catalog_path(client, catalog), method: :patch,
                          params: { status: "archived" },
                          class: "text-xs px-2 py-1 rounded text-gray-600 bg-gray-100 hover:bg-gray-200 dark:text-gray-400 dark:bg-gray-600",
                          data: { turbo_frame: "hub-catalogs" } %>
                    <% end %>
                    <%= button_to "Delete", admin_client_catalog_path(client, catalog), method: :delete,
                        class: "text-xs px-2 py-1 rounded text-red-600 bg-red-50 hover:bg-red-100 dark:text-red-400 dark:bg-red-900/30",
                        data: { turbo_frame: "hub-catalogs", turbo_confirm: "Delete this catalog and unassign all its products?" } %>
                  </div>
                </div>
              </div>

              <!-- Catalog Products -->
              <div class="p-4">
                <%= form_with url: admin_client_catalog_catalog_products_path(client, catalog), method: :patch,
                    data: { controller: "product-search",
                            product_search_url_value: admin_products_path(format: :json),
                            product_search_input_name_value: "product_ids[]",
                            turbo_frame: "hub-catalogs" } do %>

                  <!-- Search + Copy -->
                  <div class="flex items-center space-x-2 mb-3">
                    <div class="relative flex-1">
                      <input type="text"
                             data-product-search-target="searchInput"
                             data-action="input->product-search#search keydown->product-search#handleKeydown"
                             placeholder="Search products to add..."
                             class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:placeholder-gray-400">
                      <div data-product-search-target="resultsDropdown" class="hidden absolute z-10 w-full mt-1 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md shadow-lg max-h-60 overflow-y-auto">
                        <div data-product-search-target="resultsList"></div>
                      </div>
                    </div>
                    <button type="button"
                            data-action="click->copy-products#open"
                            class="flex-shrink-0 inline-flex items-center px-3 py-2 text-xs font-medium text-blue-600 bg-blue-50 border border-blue-200 rounded-md hover:bg-blue-100 dark:text-blue-400 dark:bg-blue-900/30 dark:border-blue-800 dark:hover:bg-blue-900/50"
                            title="Copy products from another client">
                      <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                      </svg>
                      Copy
                    </button>
                  </div>

                  <!-- Product List -->
                  <div data-product-search-target="selectedProducts" class="space-y-2">
                    <% catalog.products.each do |product| %>
                      <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg border border-gray-200 dark:border-gray-600" data-product-row="<%= product.id %>">
                        <div class="flex-1">
                          <h5 class="text-sm font-medium text-gray-900 dark:text-white"><%= product.name %></h5>
                          <% if product.color_names.present? %>
                            <p class="text-xs text-gray-500 dark:text-gray-400">Colors: <%= product.color_names %></p>
                          <% end %>
                        </div>
                        <button type="button"
                                class="ml-3 text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300"
                                data-action="click->product-search#removeProduct"
                                data-product-id="<%= product.id %>">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                          </svg>
                        </button>
                        <input type="hidden" name="product_ids[]" value="<%= product.id %>" data-product-search-target="hiddenInput">
                      </div>
                    <% end %>
                  </div>

                  <!-- Empty State -->
                  <div data-product-search-target="emptyState" class="<%= catalog.products.any? ? 'hidden' : '' %>">
                    <p class="text-center py-4 text-sm text-gray-500 dark:text-gray-400">No products in this catalog. Search above to add.</p>
                  </div>

                  <!-- Save -->
                  <div class="mt-3 flex justify-end">
                    <button type="submit" class="px-3 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                      Save Products
                    </button>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-6">
            <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">No catalogs yet. Create one below to start assigning products.</p>
          </div>
        <% end %>

        <!-- New Catalog Form -->
        <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
          <%= form_with url: admin_client_catalogs_path(client), method: :post, class: "flex items-center space-x-3", data: { turbo_frame: "hub-catalogs" } do %>
            <input type="text" name="catalog[name]" placeholder="New catalog name..."
                   class="flex-1 px-3 py-2 text-sm border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:placeholder-gray-400" required>
            <select name="catalog[status]" class="px-3 py-2 text-sm border border-gray-300 rounded-md dark:bg-gray-700 dark:border-gray-600 dark:text-white">
              <option value="draft">Draft</option>
              <option value="active">Active</option>
            </select>
            <button type="submit" class="px-3 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700">
              Create Catalog
            </button>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
