<div class="p-6 space-y-6" data-controller="copy-products">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @client.company_name %></h1>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Client Setup Hub</p>
    </div>
    <div class="flex space-x-3">
      <%= link_to "Edit Client", edit_admin_client_path(@client),
          class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
      <%= link_to "Back to Clients", admin_clients_path,
          class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" %>
    </div>
  </div>

  <!-- Onboarding Checklist -->
  <% unless @client.setup_complete? %>
    <%= render Admin::OnboardingChecklistComponent.new(client: @client) %>
  <% end %>

  <!-- Company Information -->
  <%= render "admin/clients/hub_company_info", client: @client %>

  <div class="grid grid-cols-3 gap-4">
    <!-- Addresses -->
    <%= render "admin/clients/hub_addresses", client: @client %>

    <!-- Users -->
    <%= render "admin/clients/hub_users", client: @client %>
  </div>

  <!-- Catalogs (with products inside each catalog) -->
  <%= render "admin/clients/hub_catalogs", client: @client, catalogs: @catalogs %>

  <!-- Recent Orders -->
  <%= render "admin/clients/hub_orders", client: @client, recent_orders: @recent_orders %>

  <!-- Inventory -->
  <%= render "admin/clients/hub_inventory", client: @client, recent_client_products: @recent_client_products %>

  <!-- Activity Summary -->
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6">
    <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Activity Summary</h3>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="text-center">
        <div class="text-2xl font-bold text-blue-600 dark:text-blue-400"><%= @client.users.count %></div>
        <div class="text-sm text-gray-500 dark:text-gray-400">Users</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-green-600 dark:text-green-400"><%= @assigned_products.size %></div>
        <div class="text-sm text-gray-500 dark:text-gray-400">Products</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-purple-600 dark:text-purple-400"><%= @client.orders.count %></div>
        <div class="text-sm text-gray-500 dark:text-gray-400">Total Orders</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-gray-600 dark:text-gray-400"><%= time_ago_in_words(@client.created_at) %></div>
        <div class="text-sm text-gray-500 dark:text-gray-400">Client Since</div>
      </div>
    </div>
  </div>
</div>
