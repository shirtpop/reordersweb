<div id="user_row_<%= user.id %>" class="flex items-center justify-between p-4">
  <div class="flex items-center">
    <div class="h-8 w-8 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center flex-shrink-0">
      <span class="text-sm font-medium text-blue-600 dark:text-blue-300"><%= user.email.first.upcase %></span>
    </div>
    <div class="ml-3">
      <p class="text-sm font-medium text-gray-900 dark:text-white"><%= user.email %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400">
        <%= user.role&.humanize || 'Client' %>
        <% if user.last_sign_in_at %>
          &middot; Last signed in <%= time_ago_in_words(user.last_sign_in_at) %> ago
        <% end %>
      </p>
    </div>
  </div>
  <div class="flex items-center space-x-3">
    <% if user.role_client? %>
      <%= link_to "Login as",
          masquerade_path(user),
          title: "Login as this user",
          data: { turbo_frame: "_top" },
          class: "px-3 py-1 border border-gray-300 dark:border-gray-500 rounded-md text-xs font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600" %>
    <% end %>
    <% if user.active? %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">
        Active
      </span>
    <% else %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-200 text-gray-700 dark:bg-gray-600 dark:text-gray-300">
        Inactive
      </span>
      <%= button_to "Activate", activate_admin_user_path(user), method: :patch,
          class: "px-3 py-1 border border-transparent rounded-md text-xs font-medium text-white bg-blue-600 hover:bg-blue-700",
          form: { data: { turbo_confirm: "Activate #{user.email} and email them their login credentials?" } } %>
    <% end %>
  </div>
</div>
