<div class="p-6 space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @client.company_name %> Products</h1>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Manage products assigned to this client</p>
    </div>
    <%= link_to "Back to Client",
                admin_client_path(@client),
                class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" %>
  </div>

  <%= render AdminSearchFieldComponent.new(form_url: admin_client_products_path(@client), method: :get, placeholder: "Search client products...") %>

  <div class="mt-8">
    <%= render 'table', products: @products, pagy: @pagy %>
  </div>
</div>
