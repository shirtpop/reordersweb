<div class="space-y-6">
  <%= render "shared/inventory_header" %>

  <!-- Product Information Header -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <%= link_to product_path(@product), class: "text-sm text-pink-600 hover:text-pink-800 inline-flex items-center mb-2" do %>
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Product
        <% end %>
        <h2 class="text-2xl font-bold text-gray-900"><%= @product.name %></h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-gray-50 rounded-lg p-4">
        <div class="text-sm text-gray-500">SKU</div>
        <div class="text-lg font-semibold text-gray-900 font-mono"><%= @product_variant.sku || 'N/A' %></div>
      </div>

      <div class="bg-gray-50 rounded-lg p-4">
        <div class="text-sm text-gray-500">Color</div>
        <div class="text-lg font-semibold text-gray-900"><%= @product_variant.color %></div>
      </div>

      <div class="bg-gray-50 rounded-lg p-4">
        <div class="text-sm text-gray-500">Size</div>
        <div class="text-lg font-semibold text-gray-900"><%= @product_variant.size %></div>
      </div>

      <div class="bg-gray-50 rounded-lg p-4">
        <div class="text-sm text-gray-500">Current Stock</div>
        <div class="text-lg font-semibold text-gray-900">
          <span class="<%= @inventory.quantity > 0 ? 'text-green-600' : 'text-red-600' %>">
            <%= @inventory.quantity %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Movement History Table -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold text-gray-900">Movement History</h3>
        <div class="text-sm text-gray-500">
          <%== pagy_info(@pagy) %>
        </div>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Date & Time
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Movement Type
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Quantity
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Adjusted By
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @inventory_movements.any? %>
            <% @inventory_movements.each do |movement| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= movement.created_at.strftime("%b %d, %Y %I:%M %p") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if Client::InventoryMovement::INCREASE_MOVEMENTS.include?(movement.movement_type.to_sym) %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      <%= movement.movement_type.humanize %>
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      <%= movement.movement_type.humanize %>
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold">
                  <% if Client::InventoryMovement::INCREASE_MOVEMENTS.include?(movement.movement_type.to_sym) %>
                    <span class="text-green-600">+<%= movement.quantity %></span>
                  <% else %>
                    <span class="text-red-600"><%= movement.quantity %></span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= movement.user.email %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-sm text-gray-500">
                No movement history found
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if @pagy.pages > 1 %>
      <div class="px-6 py-4 border-t border-gray-200">
        <%== pagy_nav(@pagy, 
          link_extra: 'class="relative inline-flex items-center px-4 py-2 text-sm font-medium border border-gray-300 bg-white text-gray-700 hover:bg-gray-50"',
          page_active_extra: 'class="z-10 relative inline-flex items-center px-4 py-2 text-sm font-medium border border-pink-500 bg-pink-50 text-pink-600"'
        ) %>
      </div>
    <% end %>
  </div>
</div>