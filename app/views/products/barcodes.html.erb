<div class="min-h-screen bg-gray-50">
  <!-- Header with Print Button -->
  <div class="bg-white shadow-sm border-b border-gray-200 no-print">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Product Barcodes</h1>
          <p class="text-sm text-gray-600 mt-1">Print barcodes for all products and variants</p>
        </div>
        <div class="flex items-center space-x-3">
          <%= link_to products_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Back to Products
          <% end %>
          <button onclick="window.print()" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-pink-600 border border-transparent rounded-lg hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
            </svg>
            Print Barcodes
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Barcodes Grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8" data-controller="barcode">
    <% if @products&.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 barcode-grid">
        <% @products.each do |product| %>
          <% if product.product_variants.any? %>
            <% product.product_variants.each do |variant| %>
              <div class="bg-white border-2 border-gray-300 rounded-lg p-6 barcode-card break-inside-avoid">
                <!-- Product Name -->
                <div class="mb-3">
                  <h3 class="text-lg font-bold text-gray-900 text-center truncate">
                    <%= product.name %>
                  </h3>
                  <% if variant.color.present? || variant.size.present? %>
                    <p class="text-sm text-gray-600 text-center mt-1">
                      <% if variant.color.present? %>
                        <span class="font-medium">Color:</span> <%= variant.color %>
                      <% end %>
                      <% if variant.color.present? && variant.size.present? %>
                        <span class="mx-1">•</span>
                      <% end %>
                      <% if variant.size.present? %>
                        <span class="font-medium">Size:</span> <%= variant.size %>
                      <% end %>
                    </p>
                  <% end %>
                </div>

                <!-- Barcode -->
                <div class="flex justify-center mb-3">
                  <svg class="barcode" 
                       data-barcode-target="barcode"
                       data-sku="<%= variant.sku %>" 
                       data-format="CODE128"
                       data-height="60"
                       data-width="2"
                       data-display-value="true"
                       data-font-size="14"></svg>
                </div>

                <!-- SKU Text (fallback) -->
                <div class="text-center">
                  <p class="text-xs font-mono text-gray-700 font-semibold">
                    SKU: <%= variant.sku %>
                  </p>
                </div>
              </div>
            <% end %>
          <% else %>
            <!-- Product without variants -->
            <div class="bg-white border-2 border-gray-300 rounded-lg p-6 barcode-card break-inside-avoid">
              <div class="mb-3">
                <h3 class="text-lg font-bold text-gray-900 text-center truncate">
                  <%= product.name %>
                </h3>
              </div>
              <div class="flex justify-center items-center py-8">
                <p class="text-sm text-gray-500 italic">No variants available</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12 bg-white rounded-lg border border-gray-200">
        <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
        </svg>
        <h3 class="text-lg font-medium text-gray-900 mb-2">No products found</h3>
        <p class="text-gray-500 mb-4">Add products to generate barcodes.</p>
        <%= link_to products_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-pink-600 bg-pink-50 border border-pink-600 rounded-lg hover:bg-pink-100" do %>
          Go to Products
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!-- Print Styles -->
<style>
  @media print {
    body {
      background: white !important;
      margin: 0 !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      font-family: Arial, sans-serif !important;
    }

    @page {
      size: A4 portrait;
      margin: 1cm;
    }

    .no-print {
      display: none !important;
    }

    .barcode-grid {
      display: grid !important;
      grid-template-columns: repeat(3, 1fr) !important;
      gap: 8mm !important;
      width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    .barcode-card {
      border: 1px solid #000 !important;
      border-radius: 4px !important;
      padding: 6mm !important;
      height: 40mm !important;
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      justify-content: space-between !important;
      align-items: center !important;
      text-align: center !important;
      page-break-inside: avoid !important;
      break-inside: avoid !important;
      box-sizing: border-box !important;
      margin: 0 !important;
      position: relative !important;
    }

    /* Ensure proper spacing between cards */
    .barcode-card + .barcode-card {
      margin-top: 0 !important;
    }

    /* Handle page breaks more gracefully */
    .barcode-card:nth-child(3n+1) {
      page-break-before: auto !important;
    }

    .barcode-card:nth-child(3n) {
      page-break-after: auto !important;
    }

    /* Prevent orphaned cards at the bottom of pages */
    .barcode-card:nth-child(3n-1):nth-last-child(2),
    .barcode-card:nth-child(3n):nth-last-child(1) {
      page-break-before: avoid !important;
    }

    /* Ensure proper page breaks for rows */
    .barcode-card:nth-child(3n+1) {
      page-break-before: avoid !important;
    }

    /* Add some breathing room at page boundaries */
    .barcode-grid {
      orphans: 3 !important;
      widows: 3 !important;
    }

    .barcode-card h3,
    .barcode-card p {
      margin: 0 !important;
      padding: 0 !important;
      font-size: 12pt !important;
      line-height: 1.2 !important;
    }

    .barcode-card small {
      font-size: 10pt !important;
      color: #333 !important;
    }

    /* Better text sizing for barcode cards */
    .barcode-card h3 {
      font-size: 10pt !important;
      font-weight: bold !important;
      margin-bottom: 1mm !important;
    }

    .barcode-card p {
      font-size: 8pt !important;
      margin-bottom: 0.5mm !important;
    }

    /* Ensure barcode SVG scales properly */
    .barcode-card svg {
      max-width: 100% !important;
      height: auto !important;
    }

    /* Remove any potential overflow issues */
    .barcode-card * {
      max-width: 100% !important;
      overflow: hidden !important;
    }
  }

  /* On-screen preview */
  .barcode-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .barcode-card {
    min-height: 180px;
    border: 1px solid #ccc;
    border-radius: 4px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
  }
</style>
