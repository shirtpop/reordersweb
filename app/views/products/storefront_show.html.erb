<turbo-frame id="storefront_content">
  <div class="container mx-auto px-4 py-8 max-w-7xl"
       data-controller="quantity-grid"
       data-base-price="<%= @product.base_price.to_f %>"
       data-minimum-order="<%= @product.minimum_order %>"
       data-bulk-prices="<%= @product.bulk_prices.to_json %>">

    <!-- Back to Storefront Link -->
    <%= link_to storefront_path(catalog_id: @catalog.id), class: "inline-flex items-center text-pink-600 hover:text-pink-700 mb-6 transition-colors" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      <span class="font-medium">Back to Store</span>
    <% end %>

  <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
    <!-- Product Header Section -->
    <div class="grid lg:grid-cols-2 gap-8 p-8">
      <!-- Product Images Gallery -->
      <div>
        <% if @product.drive_files.any? %>
          <!-- Main Image -->
          <div class="relative aspect-square bg-gradient-to-br from-gray-100 to-gray-200 rounded-2xl overflow-hidden mb-4 shadow-2xl">
            <%= image_tag @product.drive_files.first.preview_url,
                alt: @product.name,
                class: "w-full h-full object-cover transition-transform duration-700 hover:scale-110",
                referrerpolicy: "no-referrer" %>

            <!-- Shimmer Overlay -->
            <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/20 to-transparent opacity-0 hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
          </div>
        <% else %>
          <!-- Placeholder if no images -->
          <div class="aspect-square bg-gray-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-24 h-24 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
          </div>
        <% end %>
      </div>

      <!-- Product Info -->
      <div>
        <h1 class="text-4xl font-bold text-gray-900 mb-4"><%= @product.name %></h1>
        <p class="text-gray-600 text-lg mb-6 leading-relaxed"><%= @product.description %></p>

        <!-- Pricing Info Card -->
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-6 mb-6 border border-blue-100">
          <div class="flex justify-between items-center mb-3">
            <span class="text-sm font-medium text-gray-700">Base Price:</span>
            <span class="text-3xl font-bold text-gray-900">$<%= sprintf("%.2f", @product.base_price.to_f) %></span>
          </div>
          <div class="text-sm text-gray-600 mb-4">
            <span class="font-medium">Minimum order:</span> <%= @product.minimum_order %> units
          </div>

          <% if @product.bulk_prices.present? && @product.bulk_prices.any? %>
            <div class="pt-4 border-t border-blue-200">
              <p class="text-sm font-semibold text-gray-700 mb-3">💰 Bulk Pricing Tiers:</p>
              <div class="space-y-2">
                <% @product.bulk_prices.sort_by { |b| b["qty"].to_i }.each do |bulk| %>
                  <div class="flex justify-between items-center text-sm bg-white/60 rounded-lg px-3 py-2">
                    <span class="text-gray-700 font-medium"><%= bulk["qty"] %>+ units</span>
                    <span class="font-bold text-indigo-700">$<%= sprintf("%.2f", bulk["price"].to_f) %>/unit</span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Available Colors Preview -->
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-gray-700 mb-3">Available Colors:</h3>
          <div class="flex flex-wrap gap-2">
            <% @product.product_colors.each do |color| %>
              <div class="flex items-center gap-2 bg-gray-50 rounded-lg px-3 py-2 border border-gray-200">
                <div class="w-6 h-6 rounded-full border-2 border-white shadow-md"
                     style="background-color: <%= color.hex_color %>"></div>
                <span class="text-sm font-medium text-gray-700"><%= color.name.capitalize %></span>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Available Sizes Preview -->
        <div>
          <h3 class="text-sm font-semibold text-gray-700 mb-3">Available Sizes:</h3>
          <div class="flex flex-wrap gap-2">
            <% @product.sizes.each do |size| %>
              <span class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-800 border border-gray-200">
                <%= size %>
              </span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Size/Color Quantity Grid Section (CR 3.2) -->
    <%= form_with url: cart_items_path, method: :post,
                  data: {
                    turbo_frame: "_top"
                  },
                  class: "border-t border-gray-200 p-8 bg-gray-50" do |form| %>

      <%= hidden_field_tag :product_id, params[:id] %>
      <%= hidden_field_tag :catalog_id, params[:catalog_id] %>

      <div class="flex justify-between items-center mb-6">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">Select Quantities</h2>
          <p class="text-gray-600 mt-1">Enter quantities for each size and color combination</p>
        </div>
        <div class="text-right">
          <p class="text-sm text-gray-600">Total Units:</p>
          <p class="text-4xl font-bold text-pink-600" data-quantity-grid-target="totalQuantity">0</p>
        </div>
      </div>

      <!-- Color Card Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% @product.product_colors.each_with_index do |color, color_idx| %>
          <%
            images_by_angle = color.product_color_images.each_with_object({}) do |pci, h|
              h[pci.angle] = pci.drive_file if pci.drive_file
            end
            hero_image = images_by_angle["front"] || images_by_angle.values.first
            angle_labels = { "front" => "Front", "back" => "Back", "left" => "Left", "right" => "Right" }
          %>
          <input type="hidden"
                 data-quantity-grid-target="colorMinimum"
                 data-color="<%= color.name %>"
                 value="<%= color.minimum_order.to_i %>">
          <div class="bg-white rounded-2xl border-2 border-gray-200 shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden flex flex-col"
               data-controller="color-card">

            <!-- Hero Image -->
            <div class="relative aspect-square bg-gradient-to-br from-gray-100 to-gray-200">
              <% if hero_image %>
                <img src="<%= hero_image.preview_url %>"
                     alt="<%= color.name.capitalize %>"
                     referrerpolicy="no-referrer"
                     data-color-card-target="heroImage"
                     class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
              <% else %>
                <div class="w-full h-full flex items-center justify-center" data-color-card-target="heroPlaceholder">
                  <div class="w-20 h-20 rounded-full border-4 border-white shadow-xl"
                       style="background-color: <%= color.hex_color %>"></div>
                </div>
              <% end %>
              <!-- Color badge -->
              <div class="absolute top-3 right-3 flex items-center gap-1.5 bg-white/90 backdrop-blur-sm rounded-full px-2.5 py-1 shadow-sm">
                <div class="w-3.5 h-3.5 rounded-full border border-gray-200 flex-shrink-0"
                     style="background-color: <%= color.hex_color %>"></div>
                <span class="text-xs font-semibold text-gray-700"><%= color.name.capitalize %></span>
              </div>
            </div>

            <!-- Angle Thumbnail Strip -->
            <% visible_angles = ProductColorImage.angles.keys.select { |a| images_by_angle[a] } %>
            <% if visible_angles.size > 1 %>
              <div class="flex gap-2 p-3 border-b border-gray-100 bg-gray-50">
                <% visible_angles.each_with_index do |angle, i| %>
                  <% img = images_by_angle[angle] %>
                  <button type="button"
                          data-action="click->color-card#switchAngle"
                          data-url="<%= img.preview_url %>"
                          data-color-card-target="angleThumbnail"
                          title="<%= angle_labels[angle] %>"
                          class="w-14 h-14 flex-shrink-0 rounded-lg overflow-hidden border-2 transition-all duration-150 hover:border-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-400 <%= i == 0 ? 'border-pink-500 ring-2 ring-pink-500' : 'border-transparent' %>">
                    <img src="<%= img.preview_url %>"
                         alt="<%= angle_labels[angle] %>"
                         referrerpolicy="no-referrer"
                         class="w-full h-full object-cover">
                  </button>
                <% end %>
              </div>
            <% end %>

            <!-- Size Inputs -->
            <div class="p-4 flex-1">
              <div class="grid grid-cols-2 gap-4">
                <% @product.sizes.each_with_index do |size, size_idx| %>
                  <div class="rounded-md border-2 border-gray-200 bg-gray-50 p-3 transition-colors duration-150 hover:border-pink-200 hover:bg-pink-50"
                       data-size-cell>
                    <p class="text-xs font-semibold text-gray-400 text-center mb-2.5 uppercase tracking-wider"><%= size %></p>
                    <div class="flex items-center bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm">
                      <button type="button"
                              data-action="click->quantity-grid#decrement"
                              class="flex-1 h-9 flex items-center justify-center text-gray-400 hover:text-pink-600 hover:bg-pink-50 active:bg-pink-100 transition-colors duration-150">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 12H4"></path>
                        </svg>
                      </button>
                      <%= number_field_tag "items[#{size_idx}_#{color_idx}][quantity]",
                             nil,
                             class: "w-10 h-9 text-center text-sm font-bold text-gray-900 focus:outline-none border-x border-gray-200 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none",
                             min: 0,
                             placeholder: "0",
                             data: {
                               quantity_grid_target: "quantityInput",
                               action: "input->quantity-grid#updateTotals",
                               size: size,
                               color: color.name,
                               row: size,
                               col: color.name
                             } %>
                      <button type="button"
                              data-action="click->quantity-grid#increment"
                              class="flex-1 h-9 flex items-center justify-center text-gray-400 hover:text-pink-600 hover:bg-pink-50 active:bg-pink-100 transition-colors duration-150">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
                        </svg>
                      </button>
                    </div>
                    <%= hidden_field_tag "items[#{size_idx}_#{color_idx}][size]", size %>
                    <%= hidden_field_tag "items[#{size_idx}_#{color_idx}][color]", color.name %>
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Per-color minimum order indicator -->
            <div class="border-t border-amber-100 px-4 py-2 bg-amber-50 flex justify-between items-center">
              <span class="text-xs font-semibold text-amber-700 uppercase tracking-wide">Min. order</span>
              <span class="text-sm font-bold text-amber-700"><%= color.minimum_order.positive? ? color.minimum_order : @product.minimum_order %> units</span>
            </div>

            <!-- Card Color Total -->
            <div class="border-t border-gray-100 px-4 py-3 bg-gradient-to-r from-gray-50 to-pink-50 flex justify-between items-center">
              <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Color Total</span>
              <span class="text-lg font-bold text-pink-600"
                    data-quantity-grid-target="colTotal"
                    data-col="<%= color.name %>">0</span>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Grand Total (hidden, used for validation) -->
      <span class="hidden" data-quantity-grid-target="grandTotal">0</span>

      <!-- Pricing & Feedback Section -->
      <div class="mt-6 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-6 border-2 border-blue-200">
        <div class="grid md:grid-cols-2 gap-6 mb-4">
          <div class="flex justify-between items-center">
            <span class="text-sm font-medium text-gray-700">Price per Unit:</span>
            <span class="text-3xl font-bold text-gray-900" data-quantity-grid-target="pricePerUnit">
              $<%= sprintf("%.2f", @product.base_price.to_f) %>
            </span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-sm font-medium text-gray-700">Estimated Total:</span>
            <span class="text-3xl font-bold text-pink-600" data-quantity-grid-target="estimatedTotal">
              $0.00
            </span>
          </div>
        </div>

        <!-- Dynamic Feedback Messages -->
        <div class="mt-4 min-h-[2rem]">
          <div data-quantity-grid-target="feedbackMessage" class="text-sm"></div>
        </div>

        <!-- Minimum Order Warning -->
        <% if @product.minimum_order.to_i > 0 %>
          <div class="mt-4 pt-4 border-t border-blue-200">
            <div class="flex items-start gap-3">
              <svg class="w-6 h-6 text-amber-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <p class="text-sm font-medium text-amber-700">
                Minimum order requirement: <span class="font-bold"><%= @product.minimum_order %> units</span>
              </p>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Add to Cart Button -->
      <div class="mt-8">
        <%= form.submit "Add to Cart",
            class: "w-full bg-gradient-to-r from-pink-600 to-pink-700 hover:from-pink-700 hover:to-pink-800 text-white font-bold py-5 rounded-xl text-xl transition-all duration-200 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 flex items-center justify-center gap-3",
            data: { action: "click->quantity-grid#validateBeforeSubmit" } %>
      </div>
    <% end %>
  </div>
</turbo-frame>
