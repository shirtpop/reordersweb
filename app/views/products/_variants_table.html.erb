<div class="mt-8">
  <h3 class="text-lg font-medium text-gray-900 mb-4">Product Variants</h3>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden" data-controller="barcode">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Color</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Size</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">SKU</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Barcode</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Quantity</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <% product.product_variants.each do |variant| %>
        <tbody class="bg-white divide-y divide-gray-200" data-controller="variant-adjust">
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <% if variant.color.present? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  <%= variant.color %>
                </span>
              <% else %>
                <span class="text-gray-500">-</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <% if variant.size.present? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <%= variant.size %>
                </span>
              <% else %>
                <span class="text-gray-500">-</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <% if variant.sku.present? %>
                <div class="font-mono text-xs bg-gray-100 px-2 py-1 rounded inline-block">
                  <%= variant.sku %>
                </div>
              <% else %>
                <span class="text-gray-500">-</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if variant.sku.present? %>
                <svg data-barcode-target="barcode"
                      data-sku="<%= variant.sku %>"
                      data-format="CODE128"
                      data-height="32"
                      data-width="1"
                      data-display-value="false"></svg>
              <% else %>
                <span class="text-gray-400 text-xs italic">No SKU</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <% if variant.inventory.present? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= variant.inventory.quantity > 0 ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                  <%= variant.inventory.quantity %>
                </span>
              <% else %>
                <span class="text-gray-500">0</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <% inv = variant.inventory %>
              <% if inv.present? %>
                <%
                  qty = inv.quantity
                  status_class = if qty > 10
                    "bg-green-100 text-green-800"
                  elsif qty > 0
                    "bg-yellow-100 text-yellow-800"
                  else
                    "bg-red-100 text-red-800"
                  end
                  status_label = if qty > 10 then "In Stock"
                  elsif qty > 0 then "Low Stock"
                  else "Out of Stock"
                  end
                %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_class %>">
                  <%= status_label %>
                </span>
              <% else %>
                <span class="text-gray-400 text-xs">-</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <div class="flex items-center gap-2">
                <% if variant.inventory.present? %>
                  <%= link_to inventory_movements_path(variant.inventory),
                      class: "inline-flex items-center px-2.5 py-1.5 text-xs font-medium text-gray-700 bg-white border border-gray-300 rounded hover:bg-gray-50" do %>
                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                    </svg>
                    Movements
                  <% end %>
                <% end %>
                <button type="button"
                        data-action="click->variant-adjust#toggle"
                        class="inline-flex items-center px-2.5 py-1.5 text-xs font-medium text-white bg-pink-600 border border-transparent rounded hover:bg-pink-700">
                  <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                  Adjust
                </button>
              </div>
            </td>
          </tr>
          <tr data-variant-adjust-target="form" class="hidden bg-pink-50">
            <td colspan="7" class="px-6 py-4">
              <%= form_with url: save_adjustments_inventories_path, method: :post, class: "flex flex-wrap items-end gap-4" do |f| %>
                <input type="hidden" name="return_to" value="<%= product_path(product) %>">
                <input type="hidden" name="adjustments[product_variants][][product_variant_id]" value="<%= variant.id %>">
                <div>
                  <%= f.label "adjustments[movement_type]", "Movement Type", class: "block text-xs font-medium text-gray-700 mb-1" %>
                  <%= f.select "adjustments[movement_type]",
                      options_for_select((Client::InventoryMovement::ALL_MOVEMENTS - [ :delivered_in ]).map { |m| [ m.to_s.humanize, m ] }, :stock_in),
                      {},
                      class: "px-3 py-1.5 text-sm border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500" %>
                </div>
                <div>
                  <%= f.label "adjustments[product_variants][][product_variant_quantity]", "Quantity", class: "block text-xs font-medium text-gray-700 mb-1" %>
                  <%= f.number_field "adjustments[product_variants][][product_variant_quantity]",
                      min: 1, placeholder: "0",
                      class: "w-24 px-3 py-1.5 text-sm border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500" %>
                </div>
                <div class="flex items-end gap-2">
                  <%= f.submit "Save", class: "px-4 py-1.5 text-sm font-medium text-white bg-pink-600 border border-transparent rounded-md hover:bg-pink-700 cursor-pointer" %>
                  <button type="button"
                          data-action="click->variant-adjust#toggle"
                          class="px-4 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
                    Cancel
                  </button>
                </div>
              <% end %>
            </td>
          </tr>
        </tbody>
        <% end %>
      </table>
    </div>
  </div>
</div>
