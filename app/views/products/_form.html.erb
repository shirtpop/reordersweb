<%= form_with model: product, url: product.persisted? ? product_path(product) : products_path, local: true, class: "space-y-6", data: { controller: "client-product-form", turbo: false } do |form| %>
  <% if product.errors[:base].any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">
      <h4 class="font-medium">Please fix the following errors:</h4>
      <ul class="mt-2 list-disc list-inside">
        <% product.errors[:base].each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Basic Product Information -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="md:col-span-2 relative" data-controller="product-autocomplete">
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :name,
          required: true,
          data: { 
            product_autocomplete_target: "nameField",
            action: "input->product-autocomplete#search keyup->product-autocomplete#handleKeyup"
          },
          class: field_error_class(product, :name, "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500") %>
      <%= display_field_errors(product, :name) %>
      
      <!-- Hidden field for selected product ID -->
      <%= form.hidden_field :product_id, data: { product_autocomplete_target: "productIdField" } %>
      
      <!-- Autocomplete dropdown -->
      <div data-product-autocomplete-target="dropdown" class="hidden absolute z-10 w-full bg-white border border-gray-300 rounded-md shadow-lg mt-1 max-h-60 overflow-y-auto">
        <div data-product-autocomplete-target="results" class="py-1">
          <!-- Results will be populated here -->
        </div>
      </div>
    </div>
  </div>

  <!-- Description -->
  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.rich_text_area :description, 
        class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500" %>
    <%= display_field_errors(product, :description) %>
  </div>

  <!-- Product Variants -->
  <div class="border-t pt-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-medium text-gray-900">Product Variants</h3>
      <button type="button" 
              class="inline-flex items-center px-3 py-2 text-sm font-medium text-white bg-pink-600 border border-transparent rounded-lg hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500"
              data-action="click->client-product-form#addVariant">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Add Variant
      </button>
    </div>

    <div data-client-product-form-target="variantsContainer">
      <%= form.fields_for :product_variants do |variant_form| %>
        <div class="variant-row border border-gray-200 rounded-lg p-4 mb-4" data-client-product-form-target="variantRow">
          <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
              <%= variant_form.label :color, "Color", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= variant_form.text_field :color, 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500" %>
            </div>
            <div>
              <%= variant_form.label :size, "Size", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= variant_form.text_field :size, 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500" %>
            </div>
            <div>
              <%= variant_form.label :sku, "SKU", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= variant_form.text_field :sku, 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500" %>
            </div>
            <div class="flex items-end">
              <button type="button" 
                      class="w-full px-3 py-2 text-red-600 hover:text-red-800 text-sm font-medium border border-red-300 rounded-md hover:bg-red-50"
                      data-action="click->client-product-form#removeVariant">
                Remove
              </button>
            </div>
          </div>
          <%= variant_form.hidden_field :id if variant_form.object.persisted? %>
          <%= variant_form.hidden_field :_destroy, value: false %>
        </div>
      <% end %>
    </div>

    <!-- Template for new variants -->
    <template data-client-product-form-target="variantTemplate">
      <div class="variant-row border border-gray-200 rounded-lg p-4 mb-4" data-client-product-form-target="variantRow">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Color</label>
            <input type="text" 
                   name="client_product[product_variants_attributes][INDEX][color]"
                   class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Size</label>
            <input type="text" 
                   name="client_product[product_variants_attributes][INDEX][size]"
                   class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">SKU</label>
            <input type="text" 
                   name="client_product[product_variants_attributes][INDEX][sku]"
                   class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500" />
          </div>
          <div class="flex items-end">
            <button type="button" 
                    class="w-full px-3 py-2 text-red-600 hover:text-red-800 text-sm font-medium border border-red-300 rounded-md hover:bg-red-50"
                    data-action="click->client-product-form#removeVariant">
              Remove
            </button>
          </div>
        </div>
        <input type="hidden" name="client_product[product_variants_attributes][INDEX][_destroy]" value="false" />
      </div>
    </template>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center justify-end space-x-3 pt-6 border-t">
    <%= link_to "Cancel", product.persisted? ? product_path(product) : products_path, 
        class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500" %>
    <%= form.submit product.persisted? ? "Update Product" : "Create Product", 
        class: "px-4 py-2 text-sm font-medium text-white bg-pink-600 border border-transparent rounded-lg hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500" %>
  </div>
<% end %>
