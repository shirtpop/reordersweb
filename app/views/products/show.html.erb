<div class="space-y-6">
  <%= render "shared/inventory_header" %>

  <!-- Sub-Menu Tabs -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200">
    <%= render "shared/inventory_tab_navigation" %>

    <!-- Tab Content -->
    <div class="p-6">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h1 class="text-2xl font-bold text-gray-900"><%= @product.name %></h1>
          </div>
          <div class="flex items-center space-x-3">
            <%= link_to edit_product_path(@product), 
                class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-pink-600 border border-transparent rounded-lg hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
              Edit Product
            <% end %>
            <%= link_to products_path, 
                class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
              </svg>
              Back to Products
            <% end %>
          </div>
        </div>
        
        <!-- Product details content -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Product Images -->
          <div>
            <%= turbo_frame_tag "images_container_client_product", class: "space-y-4" do %>
              <%= render "images_section", product: @product %>
            <% end %>
          </div>

          <!-- Product Information -->
          <div>
            <h3 class="text-lg font-medium text-gray-900 mb-4">Product Information</h3>
            <dl class="space-y-3">
              <div>
                <dt class="text-sm font-medium text-gray-500">Name</dt>
                <dd class="text-sm text-gray-900"><%= @product.name %></dd>
              </div>
              <% if @product.description.present? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Description</dt>
                  <dd class="text-sm text-gray-900"><%= @product.description %></dd>
                </div>
              <% end %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Created</dt>
                <dd class="text-sm text-gray-900"><%= @product.created_at.strftime("%B %d, %Y") %></dd>
              </div>
              <% if @product.admin_product.present? %>
                <div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-blue-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                    </svg>
                    <span class="text-sm font-medium text-blue-800">Based on ShirtPop Product</span>
                  </div>
                  <p class="text-sm text-blue-700 mt-1">This product is based on: <strong><%= @product.admin_product.name %></strong></p>
                </div>
              <% end %>
            </dl>
          </div>
        </div>

        <!-- Product Variants Section -->
        <% if @product.product_variants.any? %>
          <%= render "variants_table", product: @product %>
        <% end %>
      </div>
    </div>
  </div>
</div>