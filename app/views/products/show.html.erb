<% workspace_body = capture do %>
  <div class="rounded-2xl border-2 border-gray-200 bg-gradient-to-b from-gray-50/50 to-white p-6 md:p-8 shadow-sm">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-8">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900"><%= @product.name %></h2>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <%= link_to edit_product_path(@product),
            class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-pink-600 to-rose-600 hover:from-pink-700 hover:to-rose-700 shadow-md transition-all duration-200" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
          Edit product
        <% end %>
        <%= link_to products_path,
            class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-gray-700 bg-white border-2 border-gray-200 hover:border-pink-300 hover:text-pink-700 transition-all duration-200" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to products
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div>
        <%= turbo_frame_tag "images_container_client_product", class: "space-y-4" do %>
          <%= render "images_section", product: @product %>
        <% end %>
      </div>

      <div>
        <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
          <span class="w-1 h-6 rounded-full bg-gradient-to-b from-pink-600 to-rose-600" aria-hidden="true"></span>
          Product information
        </h3>
        <dl class="space-y-4">
          <div class="rounded-xl border border-gray-200 bg-white px-4 py-3">
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Name</dt>
            <dd class="text-sm text-gray-900 mt-1"><%= @product.name %></dd>
          </div>
          <% if @product.description.present? %>
            <div class="rounded-xl border border-gray-200 bg-white px-4 py-3">
              <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Description</dt>
              <dd class="text-sm text-gray-900 mt-1"><%= @product.description %></dd>
            </div>
          <% end %>
          <div class="rounded-xl border border-gray-200 bg-white px-4 py-3">
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Created</dt>
            <dd class="text-sm text-gray-900 mt-1"><%= @product.created_at.strftime("%B %d, %Y") %></dd>
          </div>
          <% if @product.admin_product.present? %>
            <div class="rounded-xl border-2 border-pink-200 bg-gradient-to-br from-pink-50 to-rose-50 px-4 py-4">
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-pink-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-sm font-semibold text-pink-900">Based on Shirtpop product</span>
              </div>
              <p class="text-sm text-pink-800 mt-2">Linked to <strong><%= @product.admin_product.name %></strong></p>
            </div>
          <% end %>
        </dl>
      </div>
    </div>

    <% if @product.product_variants.any? %>
      <%= render "variants_table", product: @product %>
    <% end %>
  </div>
<% end %>
<%= render "shared/inventory_workspace", body: workspace_body %>
