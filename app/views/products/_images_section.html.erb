<%= turbo_frame_tag "images_container_client_product", class: "space-y-4" do %>
  <div class="space-y-4">
    <% if product.drive_files.any? %>
      <div class="grid grid-cols-2 gap-3">
        <% product.drive_files.each do |drive_file| %>
          <%= turbo_frame_tag "drive_file_#{drive_file.id}", class: "relative group" do %>
            <div class="aspect-square bg-gray-100 rounded-lg overflow-hidden shadow-sm">
              <%= image_tag drive_file.preview_url, 
                  class: 'w-full h-full object-cover', 
                  alt: product.name, 
                  referrerPolicy: 'no-referrer',
                  loading: 'lazy' %>
            </div>
            <div class="absolute inset-0 bg-black bg-opacity-50 opacity-0 group-hover:opacity-100 transition-opacity duration-200 rounded-lg flex items-center justify-center">
              <%= button_to delete_image_product_path(product, drive_file_id: drive_file.id),
                  method: :delete,
                  form: { 
                    data: { 
                      turbo_confirm: "Are you sure you want to delete this image?",
                      turbo_method: :delete
                    } 
                  },
                  class: "bg-red-600 hover:bg-red-700 text-white p-2 rounded-full transition-colors duration-200 shadow-lg",
                  title: "Delete image" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                        d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-gray-50 rounded-lg p-8 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
          <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" 
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No images</h3>
        <p class="mt-1 text-sm text-gray-500">Get started by uploading a new image.</p>
      </div>
    <% end %>

    <!-- Upload Section - Only show if less than 2 images -->
    <% if product.drive_files.length < 2 %>
      <div class="mt-4">
        <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 transition-colors duration-200 hover:border-gray-400" 
            data-controller="drive-upload"
            data-drive-upload-attachable-type-value="Client::Product"
            data-drive-upload-attachable-id-value="<%= product.id %>">

          <div class="text-center">
            <svg class="mx-auto h-8 w-8 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
              <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" 
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>

            <%= form_with url: upload_images_product_path(product),
                html: { 
                  multipart: true, 
                  data: { drive_upload_target: "form" },
                  class: "space-y-4"
                },
                method: :post,
                local: false do |f| %>

              <div class="mt-4">
                <button type="button" 
                        data-action="click->drive-upload#triggerFileInput"
                        class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                  </svg>
                  Add Image
                </button>
                <input id="drive-file-input-<%= product.id %>" 
                      type="file" 
                      name="file" 
                      accept="image/*" 
                      multiple="false"
                      data-drive-upload-target="fileInput"
                      data-action="change->drive-upload#handleFileSelect"
                      class="hidden" />
              </div>
            <% end %>
            
            <p class="mt-2 text-sm text-gray-500">
              Upload up to <%= 2 - product.drive_files.length %> more image<%= 2 - product.drive_files.length == 1 ? '' : 's' %>
            </p>
          </div>

          <!-- Upload Progress -->
          <div data-drive-upload-target="progressContainer" class="hidden mt-4">
            <div class="bg-gray-200 rounded-full h-2">
              <div data-drive-upload-target="progressBar" 
                  class="bg-pink-600 h-2 rounded-full transition-all duration-300" 
                  style="width: 0%"></div>
            </div>
            <p data-drive-upload-target="progressText" class="text-sm text-gray-600 mt-2">
              Uploading files...
            </p>
          </div>

          <!-- Error Messages -->
          <div data-drive-upload-target="errorContainer" class="hidden mt-4">
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">
              <p data-drive-upload-target="errorMessage"></p>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
