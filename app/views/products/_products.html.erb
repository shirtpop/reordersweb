<div class="space-y-4">
  <!-- Header with Actions -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-semibold text-gray-900">Product Inventory</h2>
      <p class="text-sm text-gray-600 mt-1">Manage and view all products in inventory</p>
    </div>
    <%= link_to new_product_path, data: { turbo_frame: "_top" }, 
        class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-pink-600 border border-transparent rounded-lg hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Add Product
    <% end %>
  </div>

  <!-- Search Form -->
  <div class="mb-6">
    <%= form_with url: products_path, method: :get, local: false, class: "flex items-center space-x-2", data: { turbo_frame: "products-content" } do |form| %>
      <div class="flex-1 max-w-md">
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <%= form.text_field :q, 
              value: params[:q], 
              placeholder: "Search by product name...", 
              class: "block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:ring-1 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
        </div>
      </div>
      <button type="submit" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-pink-600 border border-transparent rounded-lg hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        Search
      </button>
      <% if params[:q].present? %>
        <%= link_to products_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500", data: { turbo_frame: "products-content" } do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
          Clear
        <% end %>
      <% end %>
    <% end %>
  </div>

  <!-- Products Grid -->
  <% if @products&.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @products.each do |product| %>
        <div class="max-w-sm bg-white border border-gray-200 rounded-lg shadow hover:shadow-lg transition-shadow duration-300">
          <!-- Product Image -->
          <div class="aspect-[4/3] bg-gray-200 rounded-t-lg overflow-hidden">
            <% if product.drive_files.any? %>
              <%= image_tag product.drive_files.first.preview_url, 
                  alt: product.name, 
                  class: "w-full h-full object-cover object-center",
                  referrerPolicy: 'no-referrer',
                  loading: 'lazy' %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-pink-100 to-pink-200 flex items-center justify-center">
                <svg class="h-16 w-16 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
              </div>
            <% end %>
          </div>
          
          <!-- Product Info -->
          <div class="p-6">
            <div class="flex items-start justify-between mb-4">
              <h5 class="text-xl font-bold tracking-tight text-gray-900 line-clamp-2">
                <%= product.name %>
              </h5>
              <div class="flex-shrink-0 ml-2">
                <span class="bg-pink-100 text-pink-800 text-xs font-medium px-2.5 py-0.5 rounded-full">
                  <%= pluralize(product.product_variants.count, 'variant') %>
                </span>
              </div>
            </div>
            
            <%= link_to product_path(product),
                        class: "inline-flex items-center w-full justify-center px-4 py-2 text-sm font-medium text-center text-white bg-pink-700 rounded-lg hover:bg-pink-800 focus:ring-4 focus:outline-none focus:ring-pink-300 transition-colors duration-200",
                        data: { turbo_frame: "_top" } do %>
              View Details
              <svg class="rtl:rotate-180 w-3.5 h-3.5 ms-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Pagination -->
    <% if @pagy&.pages > 1 %>
      <div class="mt-8 flex justify-center">
        <div class="flex items-center space-x-2">
          <% if @pagy.prev %>
            <%= link_to products_path(page: @pagy.prev, q: params[:q]), 
                        class: "inline-flex items-center px-3 py-2 text-sm font-medium text-gray-500 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500", 
                        data: { turbo_frame: "products-content" } do %>
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Previous
            <% end %>
          <% end %>
          
          <% @pagy.series.each do |item| %>
            <% if item.is_a?(Integer) %>
              <%= link_to item, products_path(page: item, q: params[:q]), 
                          class: "inline-flex items-center px-4 py-2 text-sm font-medium #{item == @pagy.page ? 'text-pink-600 bg-pink-50 border-pink-500' : 'text-gray-500 bg-white border-gray-300 hover:bg-gray-50'} border rounded-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500", 
                          data: { turbo_frame: "products-content" } %>
            <% elsif item == :gap %>
              <span class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg">...</span>
            <% end %>
          <% end %>
          
          <% if @pagy.next %>
            <%= link_to products_path(page: @pagy.next, q: params[:q]), 
                        class: "inline-flex items-center px-3 py-2 text-sm font-medium text-gray-500 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500", 
                        data: { turbo_frame: "products-content" } do %>
              Next
              <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-12 bg-gray-50 rounded-lg border border-gray-200">
      <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
      </svg>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No products found</h3>
      <p class="text-gray-500">Start by adding your first product to the inventory.</p>
      <button class="mt-4 inline-flex items-center px-4 py-2 text-sm font-medium text-pink-600 bg-pink-50 border border-pink-600 rounded-lg hover:bg-pink-100">
        Add First Product
      </button>
    </div>
  <% end %>
</div>

<!-- Custom CSS for line clamping -->
<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
