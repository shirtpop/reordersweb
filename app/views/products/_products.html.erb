<div class="space-y-8">
  <!-- Header with Actions -->
  <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-3">
        <span class="w-1.5 h-8 rounded-full bg-gradient-to-b from-pink-600 to-rose-600" aria-hidden="true"></span>
        Product inventory
      </h2>
      <p class="text-gray-600 mt-2 ml-5">Manage and view all products in your warehouse</p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <%= link_to barcodes_products_path, data: { turbo_frame: "_top" },
          class: "inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-pink-700 bg-white border-2 border-pink-200 rounded-xl hover:bg-pink-50 hover:border-pink-300 shadow-sm transition-all duration-200" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4v16"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 4v16"></path>
        </svg>
        View Barcodes
      <% end %>
      <%= link_to new_product_path, data: { turbo_frame: "_top" },
          class: "inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-pink-600 to-rose-600 rounded-xl hover:from-pink-700 hover:to-rose-700 shadow-md hover:shadow-lg transition-all duration-200" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Add Product
      <% end %>
    </div>
  </div>

  <!-- Search Form -->
  <div>
    <%= form_with url: products_path, method: :get, local: false, class: "flex flex-col sm:flex-row sm:items-stretch gap-3 max-w-3xl", data: { turbo_frame: "tab-content" } do |form| %>
      <div class="flex-1 relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <%= form.text_field :q,
            value: params[:q],
            placeholder: "Search by product name…",
            class: "block w-full pl-10 pr-4 py-3 border-2 border-gray-200 rounded-xl bg-white shadow-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 text-sm" %>
      </div>
      <div class="flex flex-wrap gap-2">
      <button type="submit" class="inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-white bg-gradient-to-r from-pink-600 to-rose-600 rounded-xl hover:from-pink-700 hover:to-rose-700 shadow-md transition-all duration-200">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        Search
      </button>
      <% if params[:q].present? %>
        <%= link_to products_path, class: "inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-gray-700 bg-white border-2 border-gray-200 rounded-xl hover:border-pink-300 transition-all duration-200", data: { turbo_frame: "tab-content" } do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
          Clear
        <% end %>
      <% end %>
      </div>
    <% end %>
  </div>

  <!-- Products Grid -->
  <% if @products&.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @products.each do |product| %>
        <div class="max-w-sm mx-auto w-full bg-white border-2 border-gray-200 rounded-2xl shadow-md hover:shadow-xl hover:border-pink-200 transition-all duration-300 overflow-hidden flex flex-col">
          <!-- Product Image -->
          <div class="aspect-[4/3] bg-gradient-to-br from-gray-100 to-gray-200 overflow-hidden">
            <% if product.drive_files.any? %>
              <%= image_tag product.drive_files.first.preview_url, 
                  alt: product.name, 
                  class: "w-full h-full object-cover object-center",
                  referrerPolicy: 'no-referrer',
                  loading: 'lazy' %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-pink-100 to-rose-100 flex items-center justify-center">
                <svg class="h-16 w-16 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
              </div>
            <% end %>
          </div>
          
          <!-- Product Info -->
          <div class="p-6">
            <div class="flex items-start justify-between mb-4">
              <h5 class="text-xl font-bold tracking-tight text-gray-900 line-clamp-2">
                <%= product.name %>
              </h5>
              <div class="flex-shrink-0 ml-2">
                <span class="bg-gradient-to-r from-pink-100 to-rose-100 text-pink-800 text-xs font-semibold px-2.5 py-1 rounded-full border border-pink-200">
                  <%= pluralize(product.product_variants_count, 'variant') %>
                </span>
              </div>
            </div>
            
            <%= link_to product_path(product),
                        class: "inline-flex items-center w-full justify-center gap-2 px-4 py-3 text-sm font-semibold text-center text-white bg-gradient-to-r from-pink-600 to-rose-600 rounded-xl hover:from-pink-700 hover:to-rose-700 shadow-md transition-all duration-200",
                        data: { turbo_frame: "_top" } do %>
              View Details
              <svg class="rtl:rotate-180 w-3.5 h-3.5 ms-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Pagination -->
    <% if @pagy&.pages > 1 %>
      <div class="mt-10 flex justify-center">
        <div class="flex flex-wrap items-center justify-center gap-2">
          <% if @pagy.prev %>
            <%= link_to products_path(page: @pagy.prev, q: params[:q]),
                        class: "inline-flex items-center px-4 py-2.5 text-sm font-semibold text-gray-600 bg-white border-2 border-gray-200 rounded-xl hover:border-pink-300 hover:text-pink-700 transition-all",
                        data: { turbo_frame: "tab-content" } do %>
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Previous
            <% end %>
          <% end %>
          
          <% @pagy.series.each do |item| %>
            <% if item.is_a?(Integer) %>
              <%= link_to item, products_path(page: item, q: params[:q]),
                          class: "inline-flex items-center min-w-[2.5rem] justify-center px-4 py-2.5 text-sm font-semibold border-2 rounded-xl transition-all #{item == @pagy.page ? 'text-pink-700 border-pink-500 bg-gradient-to-r from-pink-50 to-rose-50' : 'text-gray-600 bg-white border-gray-200 hover:border-pink-200'}",
                          data: { turbo_frame: "tab-content" } %>
            <% elsif item == :gap %>
              <span class="inline-flex items-center px-3 py-2 text-sm font-medium text-gray-400">…</span>
            <% end %>
          <% end %>
          
          <% if @pagy.next %>
            <%= link_to products_path(page: @pagy.next, q: params[:q]),
                        class: "inline-flex items-center px-4 py-2.5 text-sm font-semibold text-gray-600 bg-white border-2 border-gray-200 rounded-xl hover:border-pink-300 hover:text-pink-700 transition-all",
                        data: { turbo_frame: "tab-content" } do %>
              Next
              <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-16 px-6 rounded-2xl border-2 border-dashed border-gray-300 bg-gradient-to-b from-gray-50 to-white">
      <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
      </svg>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No products found</h3>
      <p class="text-gray-500">Start by adding your first product to the inventory.</p>
      <button class="mt-4 inline-flex items-center px-4 py-2 text-sm font-medium text-pink-600 bg-pink-50 border border-pink-600 rounded-lg hover:bg-pink-100">
        Add First Product
      </button>
    </div>
  <% end %>
</div>

<!-- Custom CSS for line clamping -->
<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
