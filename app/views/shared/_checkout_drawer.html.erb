<div data-controller="cart-drawer">
  <%= render "shared/checkout_drawer_trigger" %>

  <div data-cart-drawer-target="backdrop"
       data-action="click->cart-drawer#closeOnBackdrop"
       class="hidden opacity-0 fixed inset-0 z-[70] bg-gray-900/50 transition-opacity duration-300"></div>

  <aside data-cart-drawer-target="panel"
         class="translate-x-full fixed top-0 right-0 z-[80] h-full w-full max-w-md bg-white shadow-2xl transition-transform duration-300 ease-out flex flex-col">
    <div class="flex items-center justify-between px-6 py-5 border-b border-gray-200">
      <h2 class="text-lg font-bold text-gray-900">Your Basket</h2>
      <button type="button" data-action="click->cart-drawer#close"
              class="p-2 text-gray-400 hover:text-gray-700 hover:bg-gray-100 rounded-full transition-colors" aria-label="Close basket">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto">
      <%= render "shared/checkout_drawer_items", checkout: current_draft_checkout %>
    </div>

    <div class="border-t border-gray-200 px-6 py-5">
      <%= link_to "Review & Checkout", new_inventory_checkout_path,
            data: { turbo_frame: "_top" },
            class: "block w-full text-center px-4 py-3 rounded-xl font-bold text-white bg-gray-900 hover:bg-gray-800 transition-colors" %>
    </div>
  </aside>
</div>
