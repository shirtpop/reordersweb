<% products_active = controller_name != "checkouts" %>
<% checkouts_active = controller_name == "checkouts" %>

<div class="border-b border-gray-200 bg-gradient-to-b from-gray-50/90 to-white px-4 py-4 md:px-8 md:py-5">
  <nav class="flex flex-wrap gap-2" aria-label="Inventory sections">
    <%= link_to products_path,
        class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 #{products_active ? 'bg-gradient-to-r from-pink-600 to-rose-600 text-white shadow-lg shadow-pink-500/20' : 'text-gray-700 bg-white border-2 border-gray-200 hover:border-pink-300 hover:text-pink-700'}" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
      </svg>
      Products
    <% end %>

    <%= link_to checkouts_path,
        class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 #{checkouts_active ? 'bg-gradient-to-r from-pink-600 to-rose-600 text-white shadow-lg shadow-pink-500/20' : 'text-gray-700 bg-white border-2 border-gray-200 hover:border-pink-300 hover:text-pink-700'}" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
      </svg>
      Checkout
    <% end %>
  </nav>
</div>
