<div class="border-b border-gray-200">
  <nav class="flex flex-wrap -mb-px" aria-label="Tabs">
    <!-- Products Tab -->
    <%= link_to products_path, 
        class: "tab-button inline-flex items-center gap-2 px-6 py-4 text-sm font-medium border-b-2 #{'border-pink-600 text-pink-600' unless controller_name == 'checkouts'} #{'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' if controller_name == 'checkouts'} focus:outline-none" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
      </svg>
      Products
    <% end %>
    <!-- Checkout Tab -->
    <%= link_to checkouts_path, 
        class: "tab-button inline-flex items-center gap-2 px-6 py-4 text-sm font-medium border-b-2 #{'border-pink-600 text-pink-600' if controller_name == 'checkouts'} #{'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' unless controller_name == 'checkouts'} focus:outline-none" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
      </svg>
      Checkout
    <% end %>
  </nav>
</div>