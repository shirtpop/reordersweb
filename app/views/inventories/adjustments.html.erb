<% workspace_body = capture do %>
  <div data-controller="inventory-adjustment" data-inventory-adjustment-search-url-value="<%= search_products_inventories_path %>">
    <div class="space-y-8">
      <!-- Search Product Section -->
      <div>
        <label for="product-search" class="block text-sm font-semibold text-gray-800 mb-2">
          Search product
        </label>
        <div class="relative max-w-2xl">
          <input type="text"
                 id="product-search"
                 data-inventory-adjustment-target="searchInput"
                 data-action="input->inventory-adjustment#search"
                 placeholder="Type product name to search…"
                 class="w-full px-4 py-3 pl-11 border-2 border-gray-200 rounded-xl bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition-all">

          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>

          <div data-inventory-adjustment-target="searchResults"
               class="hidden absolute z-20 w-full mt-2 bg-white border-2 border-gray-200 rounded-xl shadow-xl max-h-60 overflow-y-auto">
          </div>
        </div>
      </div>

      <!-- Product Variants Table -->
      <div data-inventory-adjustment-target="productTable" class="hidden">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-6 pb-6 border-b border-gray-200">
          <div>
            <h3 class="text-xl font-bold text-gray-900">
              Stock adjustment for
              <span data-inventory-adjustment-target="productName" class="text-transparent bg-clip-text bg-gradient-to-r from-pink-600 to-rose-600"></span>
            </h3>
            <p class="text-sm text-gray-600 mt-2 max-w-2xl">
              Enter the quantity to adjust. Movement type determines whether stock is added or removed.
            </p>
          </div>
          <button type="button"
                  data-action="click->inventory-adjustment#clearSearch"
                  class="inline-flex items-center justify-center px-4 py-2.5 rounded-xl text-sm font-semibold text-gray-700 bg-white border-2 border-gray-200 hover:border-pink-300 hover:text-pink-700 transition-all duration-200 flex-shrink-0">
            Clear &amp; search again
          </button>
        </div>

        <%= form_with url: save_adjustments_inventories_path, method: :post, class: "space-y-6" do |form| %>
          <div>
            <%= form.label "adjustments[movement_type]", "Movement type", class: "block text-sm font-semibold text-gray-800 mb-2" %>
            <%= form.select "adjustments[movement_type]",
                options_for_select((Client::InventoryMovement::ALL_MOVEMENTS - [ :delivered_in ]).map { |m| [ m.to_s.humanize, m ] }, :stock_in),
                {},
                class: "w-full sm:w-auto min-w-[12rem] px-4 py-2.5 border-2 border-gray-200 rounded-xl bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500" %>
          </div>

          <div data-inventory-adjustment-target="adjustmentForm" class="rounded-2xl border-2 border-gray-200 overflow-hidden shadow-sm">
            <!-- Table inserted by JS -->
          </div>

          <div class="flex flex-wrap justify-end gap-3 pt-6 border-t border-gray-200">
            <button type="button"
                    data-action="click->inventory-adjustment#clearSearch"
                    class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl text-sm font-semibold text-gray-700 bg-white border-2 border-gray-200 hover:border-pink-300 transition-all duration-200">
              Cancel
            </button>
            <%= form.submit "Save adjustments",
                class: "inline-flex items-center justify-center px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-pink-600 to-rose-600 hover:from-pink-700 hover:to-rose-700 shadow-md hover:shadow-lg transition-all duration-200 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
<%= render "shared/inventory_workspace", body: workspace_body %>
