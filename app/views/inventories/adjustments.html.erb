<div class="space-y-6">
  <%= render "shared/inventory_header" %>

  <!-- Sub-Menu Tabs -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200">
    <%= render "shared/inventory_tab_navigation" %>

    <!-- Tab Content -->
    <div class="p-6" data-controller="inventory-adjustment" data-inventory-adjustment-search-url-value="<%= search_products_inventories_path %>">
      <div class="space-y-6">
        <!-- Search Product Section -->
        <div>
          <label for="product-search" class="block text-sm font-medium text-gray-700 mb-2">
            Search Product
          </label>
          <div class="relative">
            <input type="text" 
                   id="product-search"
                   data-inventory-adjustment-target="searchInput"
                   data-action="input->inventory-adjustment#search"
                   placeholder="Type product name to search..."
                   class="w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500">
            
            <!-- Search Results Dropdown -->
            <div data-inventory-adjustment-target="searchResults" 
                 class="hidden absolute z-10 w-full mt-1 bg-white border border-gray-200 rounded-md shadow-lg max-h-60 overflow-y-auto">
            </div>
          </div>
        </div>

        <!-- Product Variants Table -->
        <div data-inventory-adjustment-target="productTable" class="hidden">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="text-lg font-medium text-gray-900">
                Stock Adjustment for: <span data-inventory-adjustment-target="productName" class="text-pink-600"></span>
              </h3>
              <p class="text-sm text-gray-500 mt-1">
                Enter the quantity to adjust. Movement type will determine if it's added or removed from stock.
              </p>
            </div>
            <button type="button" 
                    data-action="click->inventory-adjustment#clearSearch"
                    class="text-sm text-gray-500 hover:text-gray-700">
              Clear & Search Again
            </button>
          </div>

          <%= form_with url: save_adjustments_inventories_path, method: :post, class: "space-y-4" do |form| %>
            <div>
              <%= form.label "adjustments[movement_type]", "Movement Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.select "adjustments[movement_type]", 
                  options_for_select(Client::InventoryMovement::ALLOWED_MOVEMENTS.map { |m| [m.to_s.humanize, m] }, :stock_in),
                  {},
                  class: "w-auto px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500" %>
            </div>

            <div data-inventory-adjustment-target="adjustmentForm">
              <!-- Table will be inserted here by JS -->
            </div>

            <div class="flex justify-end space-x-3 pt-4 border-t">
              <button type="button" 
                      data-action="click->inventory-adjustment#clearSearch"
                      class="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                Cancel
              </button>
              <%= form.submit "Save Adjustments", 
                  class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-pink-600 hover:bg-pink-700" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>