<div class="space-y-8">
  <!-- Header with Search and Export -->
  <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-3">
        <span class="w-1.5 h-8 rounded-full bg-gradient-to-b from-pink-600 to-rose-600" aria-hidden="true"></span>
        Stock levels
      </h2>
      <p class="text-gray-600 mt-2 ml-5">Monitor current stock across all product variants</p>
    </div>
    <div class="flex flex-shrink-0">
      <button type="button" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-gray-800 bg-white border-2 border-gray-200 hover:border-pink-300 hover:text-pink-700 shadow-sm transition-all duration-200" onclick="exportToCSV()">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
        </svg>
        Export CSV
      </button>
    </div>
  </div>

  <%= form_with url: inventories_path(tab: "stock-list"), method: :get, local: false, class: "flex flex-col sm:flex-row sm:items-stretch gap-3 max-w-3xl", data: { turbo_frame: "tab-content" } do |form| %>
    <div class="flex-1 relative">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <%= form.text_field :q,
          value: params[:q],
          placeholder: "Search by product, color, size, or SKU…",
          class: "block w-full pl-10 pr-4 py-3 border-2 border-gray-200 rounded-xl bg-white shadow-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 text-sm" %>
    </div>
    <div class="flex flex-wrap gap-2">
      <button type="submit" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-pink-600 to-rose-600 hover:from-pink-700 hover:to-rose-700 shadow-md transition-all duration-200">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        Search
      </button>
      <% if params[:q].present? %>
        <%= link_to inventories_path(tab: "stock-list"), class: "inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl text-sm font-semibold text-gray-700 bg-white border-2 border-gray-200 hover:border-pink-300 transition-all duration-200", data: { turbo_frame: "tab-content" } do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
          Clear
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="rounded-2xl border-2 border-emerald-200 bg-gradient-to-br from-emerald-50 to-teal-50 p-5 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-sm font-semibold text-emerald-700">In stock</p>
          <p class="text-3xl font-bold text-emerald-900 mt-1 tabular-nums"><%= @in_stock_count %></p>
        </div>
        <div class="p-3 rounded-xl bg-emerald-200/80 shadow-inner">
          <svg class="w-7 h-7 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border-2 border-amber-200 bg-gradient-to-br from-amber-50 to-orange-50 p-5 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-sm font-semibold text-amber-800">Low stock</p>
          <p class="text-3xl font-bold text-amber-950 mt-1 tabular-nums"><%= @low_stock_count %></p>
        </div>
        <div class="p-3 rounded-xl bg-amber-200/80 shadow-inner">
          <svg class="w-7 h-7 text-amber-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
          </svg>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border-2 border-rose-200 bg-gradient-to-br from-rose-50 to-red-50 p-5 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-sm font-semibold text-rose-800">Out of stock</p>
          <p class="text-3xl font-bold text-rose-950 mt-1 tabular-nums"><%= @out_of_stock_count %></p>
        </div>
        <div class="p-3 rounded-xl bg-rose-200/80 shadow-inner">
          <svg class="w-7 h-7 text-rose-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <% if @inventories.any? %>
    <div class="rounded-2xl border-2 border-gray-200 overflow-hidden shadow-md bg-white">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr class="bg-gradient-to-r from-gray-50 to-gray-100 border-b-2 border-gray-200">
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">
                <%= link_to inventories_path(tab: "stock-list", q: params[:q], sort_by: params[:sort_by] == "product_name_asc" ? "product_name_desc" : "product_name_asc"),
                    class: "group inline-flex items-center gap-1 text-gray-700 hover:text-pink-700",
                    data: { turbo_frame: "tab-content" } do %>
                  Product
                  <svg class="h-4 w-4 text-gray-400 group-hover:text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <% if params[:sort_by] == "product_name_asc" %>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
                    <% elsif params[:sort_by] == "product_name_desc" %>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    <% else %>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path>
                    <% end %>
                  </svg>
                <% end %>
              </th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Color</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Size</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">SKU</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">
                <%= link_to inventories_path(tab: "stock-list", q: params[:q], sort_by: params[:sort_by] == "quantity_asc" ? "quantity_desc" : "quantity_asc"),
                    class: "group inline-flex items-center gap-1 text-gray-700 hover:text-pink-700",
                    data: { turbo_frame: "tab-content" } do %>
                  Quantity
                  <svg class="h-4 w-4 text-gray-400 group-hover:text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <% if params[:sort_by] == "quantity_asc" %>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
                    <% elsif params[:sort_by] == "quantity_desc" %>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    <% else %>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path>
                    <% end %>
                  </svg>
                <% end %>
              </th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Status</th>
              <th scope="col" class="px-6 py-4 text-center text-xs font-bold text-gray-600 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @inventories.each do |inventory| %>
              <% variant = inventory.client_product_variant %>
              <% product = variant.client_product %>
              <tr class="hover:bg-gradient-to-r hover:from-pink-50/40 hover:to-transparent transition-colors duration-150">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-4">
                    <div class="flex-shrink-0 h-11 w-11 rounded-xl bg-gradient-to-br from-pink-100 to-rose-100 border border-pink-200 flex items-center justify-center">
                      <svg class="h-6 w-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                      </svg>
                    </div>
                    <div class="min-w-0">
                      <div class="text-sm font-semibold text-gray-900"><%= product.name %></div>
                      <% if product.description.present? %>
                        <div class="text-sm text-gray-500 truncate max-w-xs">
                          <%= truncate(strip_tags(product.description.to_s), length: 50) %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <% if variant.color.present? %>
                      <div class="flex-shrink-0 h-4 w-4 rounded-full ring-2 ring-white shadow border border-gray-200" style="background-color: <%= variant.color.downcase %>"></div>
                    <% end %>
                    <span class="text-sm text-gray-900"><%= variant.color.present? ? variant.color : "N/A" %></span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= variant.size.present? ? variant.size : "N/A" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 font-mono">
                  <%= variant.sku.present? ? variant.sku : "N/A" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="text-sm font-bold text-gray-900 tabular-nums"><%= inventory.quantity %></span>
                  <span class="ml-1 text-xs text-gray-500">units</span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if inventory.quantity > 10 %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800 border border-emerald-200">
                      In stock
                    </span>
                  <% elsif inventory.quantity > 0 %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-900 border border-amber-200">
                      Low stock
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-rose-100 text-rose-800 border border-rose-200">
                      Out of stock
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-center">
                  <%= link_to inventory_movements_path(inventory), class: "inline-flex items-center justify-center p-2 rounded-xl text-pink-600 hover:bg-pink-50 border-2 border-transparent hover:border-pink-200 transition-all duration-200", title: "View movements", data: { turbo_frame: "_top" } do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-4 py-4 sm:px-6 bg-gradient-to-b from-gray-50/80 to-white border-t-2 border-gray-200">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-sm text-gray-600">
              Showing <span class="font-semibold text-gray-900"><%= @pagy.from %></span>–<span class="font-semibold text-gray-900"><%= @pagy.to %></span> of <span class="font-semibold text-gray-900"><%= @pagy.count %></span>
            </p>
            <nav class="flex flex-wrap items-center justify-center gap-1" aria-label="Pagination">
              <% if @pagy.prev %>
                <%= link_to inventories_path(tab: "stock-list", page: @pagy.prev, q: params[:q]),
                    class: "inline-flex items-center justify-center p-2 rounded-xl border-2 border-gray-200 bg-white text-gray-600 hover:border-pink-300 hover:text-pink-700 transition-all",
                    data: { turbo_frame: "tab-content" } do %>
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                <% end %>
              <% end %>

              <% @pagy.series.each do |item| %>
                <% if item.is_a?(Integer) %>
                  <%= link_to item, inventories_path(tab: "stock-list", page: item, q: params[:q]),
                      class: "min-w-[2.5rem] inline-flex items-center justify-center px-3 py-2 rounded-xl text-sm font-semibold border-2 transition-all #{item == @pagy.page ? 'border-pink-500 bg-gradient-to-r from-pink-50 to-rose-50 text-pink-700' : 'border-gray-200 bg-white text-gray-600 hover:border-pink-200'}",
                      data: { turbo_frame: "tab-content" } %>
                <% elsif item == :gap %>
                  <span class="inline-flex items-center px-2 py-2 text-sm font-medium text-gray-400">…</span>
                <% end %>
              <% end %>

              <% if @pagy.next %>
                <%= link_to inventories_path(tab: "stock-list", page: @pagy.next, q: params[:q]),
                    class: "inline-flex items-center justify-center p-2 rounded-xl border-2 border-gray-200 bg-white text-gray-600 hover:border-pink-300 hover:text-pink-700 transition-all",
                    data: { turbo_frame: "tab-content" } do %>
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                  </svg>
                <% end %>
              <% end %>
            </nav>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 px-6 rounded-2xl border-2 border-dashed border-gray-300 bg-gradient-to-b from-gray-50 to-white">
      <svg class="mx-auto h-14 w-14 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
      </svg>
      <h3 class="text-xl font-bold text-gray-900 mb-2">No inventory items found</h3>
      <p class="text-gray-600 max-w-md mx-auto">Try another search or add products from the Products tab.</p>
    </div>
  <% end %>
</div>

<script>
function exportToCSV() {
  const url = new URL('<%= inventories_path(format: :csv) %>', window.location.origin);
  <% if params[:q].present? %>
    url.searchParams.append('q', '<%= j params[:q] %>');
  <% end %>
  <% if params[:sort_by].present? %>
    url.searchParams.append('sort_by', '<%= j params[:sort_by] %>');
  <% end %>
  window.location.href = url.toString();
}
</script>
