<div class="container mx-auto px-4 py-8 max-w-7xl">
  <div class="space-y-8">
    <div>
      <h1 class="text-3xl lg:text-4xl font-bold mb-2 bg-gradient-to-r from-gray-900 via-pink-800 to-gray-900 bg-clip-text text-transparent">
        Checkout
      </h1>
      <p class="text-lg text-gray-600 flex items-center gap-2 flex-wrap">
        <svg class="w-5 h-5 text-pink-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
        </svg>
        <span>Manage and track all checkout records</span>
      </p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg border-2 border-gray-200 overflow-hidden">
      <div class="p-6 md:p-8">
        <%= turbo_frame_tag "tab-content" do %>
          <%= render "checkouts" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
