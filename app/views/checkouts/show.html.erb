<% workspace_body = capture do %>
  <div class="space-y-8">
    <nav class="flex" aria-label="Breadcrumb">
      <%= link_to inventory_checkouts_path, class: "inline-flex items-center gap-2 text-sm font-semibold text-gray-600 hover:text-pink-600 transition-colors" do %>
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to checkouts
      <% end %>
    </nav>

    <div class="rounded-2xl border-2 border-gray-200 bg-white shadow-lg overflow-hidden">
      <div class="bg-gradient-to-r from-pink-600 to-rose-600 px-6 py-5 md:px-8">
        <h2 class="text-lg font-bold text-white">Recipient information</h2>
        <p class="text-sm text-pink-100 mt-1">Who received this inventory checkout</p>
      </div>
      <div class="p-6 md:p-8">
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="rounded-xl border border-gray-100 bg-gradient-to-br from-gray-50 to-white p-4">
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Name</dt>
            <dd class="mt-1 text-sm font-semibold text-gray-900"><%= @checkout.recipient_full_name %></dd>
          </div>
          <div class="rounded-xl border border-gray-100 bg-gradient-to-br from-gray-50 to-white p-4">
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Email</dt>
            <dd class="mt-1 text-sm font-semibold text-gray-900 break-all"><%= @checkout.recipient_email %></dd>
          </div>
          <div class="rounded-xl border border-gray-100 bg-gradient-to-br from-gray-50 to-white p-4">
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Created by</dt>
            <dd class="mt-1 text-sm font-semibold text-gray-900 break-all"><%= @checkout.user.email %></dd>
          </div>
          <div class="rounded-xl border border-gray-100 bg-gradient-to-br from-gray-50 to-white p-4">
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Date</dt>
            <dd class="mt-1 text-sm font-semibold text-gray-900"><%= @checkout.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="rounded-2xl border-2 border-gray-200 bg-white shadow-md overflow-hidden">
      <div class="px-6 py-5 border-b-2 border-gray-100 bg-gradient-to-r from-gray-50 to-gray-100 flex items-center gap-2">
        <span class="w-1 h-7 rounded-full bg-gradient-to-b from-pink-600 to-rose-600" aria-hidden="true"></span>
        <h2 class="text-lg font-bold text-gray-900">Checkout items</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr class="bg-gray-50/90">
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Product</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">SKU</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Color</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Size</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Quantity</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @checkout.inventory_movements.each do |movement| %>
              <% variant = movement.client_inventory.client_product_variant %>
              <% product = variant.client_product %>
              <tr class="hover:bg-pink-50/30 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-semibold text-gray-900"><%= product.name %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-600 font-mono"><%= variant.sku %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900"><%= variant.color || "N/A" %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900"><%= variant.size || "N/A" %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="text-sm font-bold text-gray-900 tabular-nums"><%= movement.quantity.abs %></span>
                  <span class="ml-1 text-xs text-gray-500">units</span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>
<%= render "shared/inventory_workspace", body: workspace_body %>
