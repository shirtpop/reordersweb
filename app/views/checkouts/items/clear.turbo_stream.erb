<%= turbo_stream.remove "clear-draft-items" %>
<%= turbo_stream.replace "checkout-drawer-items" do %>
  <%= render "shared/checkout_drawer_items", checkout: @checkout %>
<% end %>

<%= turbo_stream.replace "checkout-drawer-trigger" do %>
  <%= render "shared/checkout_drawer_trigger" %>
<% end %>

<%= turbo_stream.replace "checkout-draft-items" do %>
  <%= render "checkouts/draft_items", checkout: @checkout %>
<% end %>
