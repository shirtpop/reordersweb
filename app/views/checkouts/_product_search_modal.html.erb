<div data-checkout-form-target="productSearchModal" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <!-- Background overlay -->
  <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" data-action="click->checkout-form#closeProductSearchModal"></div>

  <!-- Modal panel container -->
  <div class="flex min-h-full items-center justify-center p-4">
    <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-4xl" data-action="click->checkout-form#stopPropagation">
      <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-medium text-gray-900" id="modal-title">Search Product</h3>
          <button type="button" 
                  class="text-gray-400 hover:text-gray-500 focus:outline-none"
                  data-action="click->checkout-form#closeProductSearchModal">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Product Search Input -->
        <div class="mb-6">
          <label for="product_search_input" class="block text-sm font-medium text-gray-700 mb-2">Search Product</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <input type="text" 
                  id="product_search_input"
                  data-checkout-form-target="productSearchInput"
                  data-action="input->checkout-form#handleProductSearch"
                  class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500 sm:text-sm"
                  placeholder="Type at least 3 characters to search...">
          </div>
          <p class="mt-1 text-xs text-gray-500">Start typing to search for products by name</p>
        </div>

        <!-- Product Autocomplete Results -->
        <div data-checkout-form-target="productAutocomplete" class="hidden mb-6">
          <div class="border border-gray-200 rounded-md max-h-60 overflow-y-auto">
            <ul class="divide-y divide-gray-200">
              <!-- Product results will be inserted here -->
            </ul>
          </div>
        </div>

        <!-- Selected Product Info -->
        <div data-checkout-form-target="selectedProductInfo" class="hidden mb-6 p-4 bg-gray-50 rounded-lg border border-gray-200">
          <h4 class="text-sm font-medium text-gray-900 mb-2">Selected Product:</h4>
          <p class="text-sm text-gray-700" data-checkout-form-target="selectedProductName"></p>
        </div>

        <!-- Product Variants Table -->
        <div data-checkout-form-target="variantsContainer" class="hidden">
          <h4 class="text-sm font-medium text-gray-900 mb-3">Product Variants</h4>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    <input type="checkbox" 
                          data-checkout-form-target="selectAllVariants"
                          data-action="change->checkout-form#toggleAllVariants"
                          class="rounded border-gray-300 text-pink-600 focus:ring-pink-500">
                  </th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">SKU</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Color</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Size</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Available</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200" data-checkout-form-target="variantsTableBody">
                <!-- Variants will be inserted here -->
              </tbody>
            </table>
          </div>
        </div>

        <!-- Loading State -->
        <div data-checkout-form-target="loadingState" class="hidden text-center py-8">
          <svg class="animate-spin h-8 w-8 text-pink-600 mx-auto" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <p class="mt-2 text-sm text-gray-600">Loading...</p>
        </div>

        <!-- Error State -->
        <div data-checkout-form-target="modalError" class="hidden mt-4 p-3 bg-red-50 border border-red-200 rounded-md">
          <p class="text-sm text-red-600"></p>
        </div>
      </div>

      <!-- Modal Footer -->
      <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
        <button type="button" 
                class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-pink-600 text-base font-medium text-white hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500 sm:ml-3 sm:w-auto sm:text-sm"
                data-action="click->checkout-form#addSelectedVariants">
          Add Selected Variants
        </button>
        <button type="button" 
                class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm"
                data-action="click->checkout-form#closeProductSearchModal">
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>
