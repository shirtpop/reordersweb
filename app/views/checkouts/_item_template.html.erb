<template data-checkout-form-target="itemTemplate">
  <tr data-item-row>
    <td class="px-6 py-4 whitespace-nowrap">
      <div class="text-sm font-medium text-gray-900" data-field="product-name"></div>
    </td>
    <td class="px-6 py-4 whitespace-nowrap">
      <div class="text-sm text-gray-500" data-field="sku"></div>
    </td>
    <td class="px-6 py-4 whitespace-nowrap">
      <div class="text-sm text-gray-900" data-field="color"></div>
    </td>
    <td class="px-6 py-4 whitespace-nowrap">
      <div class="text-sm text-gray-900" data-field="size"></div>
    </td>
    <td class="px-6 py-4 whitespace-nowrap">
      <div class="text-sm text-gray-500" data-field="available"></div>
    </td>
    <td class="px-6 py-4 whitespace-nowrap">
      <input type="number" 
            name="client_checkout[inventory_movements_attributes][INDEX][quantity]" 
            min="1" 
            value="1"
            data-field="quantity-input"
            class="block w-20 px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-pink-500 focus:border-pink-500 sm:text-sm">
      <input type="hidden" name="client_checkout[inventory_movements_attributes][INDEX][client_inventory_id]" data-field="inventory-id">
      <input type="hidden" name="client_checkout[inventory_movements_attributes][INDEX][movement_type]" value="stock_out">
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
      <button type="button" 
              data-action="click->checkout-form#removeItem"
              class="text-red-600 hover:text-red-900">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
      </button>
    </td>
  </tr>
</template>