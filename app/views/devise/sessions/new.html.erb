<div class="max-w-md w-full space-y-6">
  <!-- Header Card -->
  <div class="bg-gradient-to-r from-pink-600 to-rose-600 rounded-2xl shadow-2xl p-8 text-white text-center">
    <div class="mx-auto h-20 w-20 bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center mb-4 shadow-lg">
      <svg class="h-10 w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
      </svg>
    </div>
    <h2 class="text-3xl font-bold mb-2">
      Welcome Back!
    </h2>
    <p class="text-pink-100">
      Sign in to continue to Shirtpop Reorders
    </p>
  </div>

  <!-- Form -->
  <div class="bg-white rounded-2xl shadow-2xl border-2 border-gray-200 p-8">
    <%= form_with model: resource, as: resource_name, url: session_path(resource_name), 
                  local: true, class: "space-y-6", data: { controller: "form" } do |form| %>
      
      <!-- Email Field -->
      <div>
        <%= form.label :email, class: "block text-sm font-bold text-gray-700 mb-2" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path>
            </svg>
          </div>
          <%= form.email_field :email,
                               autofocus: true,
                               autocomplete: "email",
                               placeholder: "Enter your email",
                               class: "block w-full pl-10 pr-3 py-3 border-2 border-gray-300 rounded-lg leading-5 bg-gray-50 placeholder-gray-400 focus:outline-none focus:bg-white focus:border-pink-500 focus:ring-2 focus:ring-pink-200 transition-all duration-200" %>
        </div>
      </div>

      <!-- Password Field -->
      <div>
        <%= form.label :password, class: "block text-sm font-bold text-gray-700 mb-2" %>
        <div class="relative" data-controller="password-toggle">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <%= form.password_field :password,
                                  autocomplete: "current-password",
                                  placeholder: "Enter your password",
                                  data: { "password-toggle-target": "input" },
                                  class: "block w-full pl-10 pr-12 py-3 border-2 border-gray-300 rounded-lg leading-5 bg-gray-50 placeholder-gray-400 focus:outline-none focus:bg-white focus:border-pink-500 focus:ring-2 focus:ring-pink-200 transition-all duration-200" %>
          <button type="button"
                  class="absolute inset-y-0 right-0 pr-3 flex items-center z-10 cursor-pointer hover:text-pink-600 transition-colors"
                  data-action="password-toggle#toggle">
            <svg xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 text-gray-400 pointer-events-none"
                fill="none" viewBox="0 0 24 24" stroke="currentColor"
                data-password-toggle-target="icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Remember Me & Forgot Password -->
      <div class="flex items-center justify-between">
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= form.check_box :remember_me, class: "h-4 w-4 text-pink-600 focus:ring-pink-500 border-gray-300 rounded cursor-pointer" %>
            <%= form.label :remember_me, "Remember me", class: "ml-2 block text-sm font-medium text-gray-700 cursor-pointer" %>
          </div>
        <% end %>

        <div class="text-sm">
          <%= link_to "Forgot password?", new_password_path(resource_name),
                      class: "font-bold text-pink-600 hover:text-pink-700 transition-colors" %>
        </div>
      </div>

      <!-- Submit Button -->
      <div>
        <%= form.submit "Sign in",
                        class: "group relative w-full flex justify-center gap-2 py-3.5 px-4 border border-transparent text-base font-bold rounded-lg text-white bg-gradient-to-r from-pink-600 to-rose-600 hover:from-pink-700 hover:to-rose-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200" %>
      </div>
    <% end %>
  </div>

  <!-- Flash Messages -->
  <% if notice %>
    <div class="bg-green-50 border-2 border-green-300 rounded-xl p-4 shadow-lg">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-green-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <p class="ml-3 text-sm font-medium text-green-800"><%= notice %></p>
      </div>
    </div>
  <% end %>

  <% if alert %>
    <div class="bg-red-50 border-2 border-red-300 rounded-xl p-4 shadow-lg">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-red-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <p class="ml-3 text-sm font-medium text-red-800"><%= alert %></p>
      </div>
    </div>
  <% end %>
</div>
