<div class="min-h-screen bg-gradient-to-br from-gray-50 to-pink-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <!-- Change Password Card -->
    <div class="bg-white rounded-2xl shadow-2xl border-2 border-gray-200">
      <div class="px-6 py-5 border-b-2 border-gray-200">
        <h2 class="text-lg font-bold text-gray-900">Change Password</h2>
        <p class="mt-1 text-sm text-gray-600">Update your password to keep your account secure</p>
      </div>

      <%= form_for(resource, as: resource_name, url: user_registration_path, html: { method: :put, class: "px-6 py-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <!-- Current Password -->
          <% unless current_user.first_time_login? %>
            <div>
              <%= f.label :current_password, "Current Password", class: "block text-sm font-bold text-gray-700 mb-2" %>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                  <svg class="h-5 w-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                  </svg>
                </div>
                <%= f.password_field :current_password,
                      autocomplete: "current-password",
                      placeholder: "Enter your current password",
                      class: "block w-full pl-10 pr-3 py-3 border-2 border-gray-300 rounded-lg bg-gray-50 text-gray-900 placeholder-gray-400 focus:outline-none focus:bg-white focus:border-pink-500 focus:ring-2 focus:ring-pink-200 transition-all duration-200" %>
              </div>
              <p class="mt-1 text-xs text-gray-500">Required to confirm your identity</p>
            </div>
          <% end %>

          <div class="border-t-2 border-gray-200 pt-6"></div>

          <!-- New Password -->
          <div data-controller="password-toggle">
            <%= f.label :password, "New Password", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
              </div>
              <%= f.password_field :password,
                    autocomplete: "new-password",
                    placeholder: "Enter new password",
                    data: { "password-toggle-target": "input" },
                    class: "block w-full pl-10 pr-12 py-3 border-2 border-gray-300 rounded-lg bg-gray-50 text-gray-900 placeholder-gray-400 focus:outline-none focus:bg-white focus:border-pink-500 focus:ring-2 focus:ring-pink-200 transition-all duration-200" %>
              <button type="button"
                      class="absolute inset-y-0 right-0 pr-3 flex items-center z-10 cursor-pointer hover:text-pink-600 transition-colors"
                      data-action="password-toggle#toggle">
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="h-5 w-5 text-gray-400 pointer-events-none"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor"
                     data-password-toggle-target="icon">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </button>
            </div>
            <% if @minimum_password_length %>
              <p class="mt-1 text-xs text-gray-500">
                Minimum <%= @minimum_password_length %> characters required
              </p>
            <% end %>
          </div>

          <!-- Password Confirmation -->
          <div data-controller="password-toggle">
            <%= f.label :password_confirmation, "Confirm New Password", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <%= f.password_field :password_confirmation,
                    autocomplete: "new-password",
                    placeholder: "Confirm new password",
                    data: { "password-toggle-target": "input" },
                    class: "block w-full pl-10 pr-12 py-3 border-2 border-gray-300 rounded-lg bg-gray-50 text-gray-900 placeholder-gray-400 focus:outline-none focus:bg-white focus:border-pink-500 focus:ring-2 focus:ring-pink-200 transition-all duration-200" %>
              <button type="button"
                      class="absolute inset-y-0 right-0 pr-3 flex items-center z-10 cursor-pointer hover:text-pink-600 transition-colors"
                      data-action="password-toggle#toggle">
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="h-5 w-5 text-gray-400 pointer-events-none"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor"
                     data-password-toggle-target="icon">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </button>
            </div>
            <p class="mt-1 text-xs text-gray-500">
              Must match the password above
            </p>
          </div>
        </div>

        <!-- Actions -->
        <div class="mt-6 pt-6 border-t-2 border-gray-200 flex items-center justify-between">
          <%= link_to "Cancel", :back, class: "px-4 py-2 text-sm font-bold text-gray-700 hover:text-pink-600 transition-colors" %>
          <%= f.submit "Update Password",
              class: "group relative flex justify-center gap-2 py-3 px-6 border border-transparent text-base font-bold rounded-lg text-white bg-gradient-to-r from-pink-600 to-rose-600 hover:from-pink-700 hover:to-rose-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200" %>
        </div>
      <% end %>
    </div>

    <!-- Account Actions -->
    <div class="mt-6 bg-white rounded-2xl shadow-2xl border-2 border-gray-200 overflow-hidden">
      <div class="px-6 py-4">
        <h3 class="text-sm font-bold text-gray-900">Need Help?</h3>
        <p class="mt-1 text-sm text-gray-600">
          If you're experiencing issues with your account, please contact support.
        </p>
      </div>
    </div>
  </div>
</div>
