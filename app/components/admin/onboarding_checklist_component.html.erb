<div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6" id="onboarding-checklist">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-medium text-gray-900 dark:text-white">Setup Progress</h3>
    <span class="text-sm font-medium <%= all_complete? ? 'text-green-600 dark:text-green-400' : 'text-blue-600 dark:text-blue-400' %>">
      <%= completed_count %>/<%= total_count %> complete
    </span>
  </div>

  <!-- Progress Bar -->
  <div class="w-full bg-gray-200 rounded-full h-2.5 dark:bg-gray-700 mb-6">
    <div class="h-2.5 rounded-full transition-all duration-300 <%= all_complete? ? 'bg-green-500' : 'bg-blue-600' %>"
         style="width: <%= @progress %>%"></div>
  </div>

  <!-- Checklist -->
  <div class="space-y-3">
    <% steps_with_status.each do |step| %>
      <div class="flex items-center">
        <% if step[:done] %>
          <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
        <% else %>
          <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm0-2a6 6 0 100-12 6 6 0 000 12z" clip-rule="evenodd"></path>
          </svg>
        <% end %>
        <span class="ml-3 text-sm <%= step[:done] ? 'text-gray-500 dark:text-gray-400 line-through' : 'text-gray-900 dark:text-white font-medium' %>">
          <%= step[:label] %>
        </span>
      </div>
    <% end %>
  </div>
</div>
